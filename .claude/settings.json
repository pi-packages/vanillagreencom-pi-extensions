{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-lint.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}
