#!/usr/bin/env bash
# Poll a single tracked window — read bell flag, capture pane 0, classify.
#
# Outputs a single JSON object describing the window's current observable
# state. Intended to be called per-tracked-window in the watch loop.
#
# Usage:
#   pane-poll <window-target> [<pane-index>] [--harness <h>]
#   pane-poll HT:cc-463
#   pane-poll HT:cc-463 0 --harness opencode
#
# JSON fields:
#   {
#     "window": "HT:cc-463",
#     "pane_target": "HT:cc-463.0",
#     "bell": true|false,
#     "activity": true|false,
#     "silence": true|false,
#     "tag": "rebase-multi-choice" | "rendering" | "idle" | ...,
#     "capture_hash": "sha256:..."
#   }
#
# Exit codes:
#   0 - success (window exists, captured, classified)
#   1 - window not found
#   2 - bad arguments / not in tmux
set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "Error: not inside a tmux session" >&2
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

TARGET="${1:-}"
if [[ -z "$TARGET" ]]; then
  echo "Usage: pane-poll <window-target>" >&2
  exit 2
fi

# Optional: pinned pane index (default 0)
PANE_INDEX="${2:-0}"
shift || true; shift || true

HARNESS=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --harness) HARNESS="$2"; shift 2 ;;
    --harness=*) HARNESS="${1#--harness=}"; shift ;;
    *) shift ;;
  esac
done

PANE_TARGET="${TARGET}.${PANE_INDEX}"

# Per-harness capture strategy. Some TUIs (notably opencode) sometimes
# scroll the rendered buffer above the viewport, so `-S -200` returns
# stale middle content and misses the live prompt. For those, capture
# only the visible viewport. Document additions in patterns/tmux-monitoring.md
# § Per-harness signals.
case "$HARNESS" in
  opencode) CAPTURE_ARGS=(-p) ;;
  *)        CAPTURE_ARGS=(-p -S -200) ;;
esac

# Strip OSC color-query response leakage from captured opencode buffers.
# Opencode's TUI does not consume OSC 4 / OSC 10 / OSC 11 / OSC 12
# responses from the terminal; they land in the input buffer and get
# captured back verbatim as text like "4;150;rgb:afaf/d7d7/8787".
# Filtering here keeps fingerprints stable (the leak otherwise causes
# spurious hash churn that delays daemon stability classification) and
# prevents the leak from being fed back into pane-respond as typed input.
strip_osc_leak() {
  if [[ "$HARNESS" == "opencode" ]]; then
    # OSC 4 (palette color) and OSC 10/11/12 (fg/bg/cursor) responses.
    # Match the post-stripping text form (most common) and the raw OSC
    # framing if it slipped past tmux. Anchored to digits-then-rgb so we
    # don't eat legitimate text that happens to mention 'rgb:'.
    sed -E -e 's/(^|[[:space:]])[0-9]+;[0-9]+;rgb:[0-9a-fA-F]{4}\/[0-9a-fA-F]{4}\/[0-9a-fA-F]{4}//g' \
           -e 's/\x1b\][0-9]+;[^\x07\x1b]*(\x07|\x1b\\)//g'
  else
    cat
  fi
}

# Verify window exists; emit dead state if not.
if ! tmux list-windows -t "${TARGET%:*}" -F '#{window_index}:#{window_name}' 2>/dev/null \
     | awk -F: -v w="${TARGET#*:}" '$2 == w {found=1} END {exit !found}'; then
  jq -n --arg w "$TARGET" --arg p "$PANE_TARGET" '{window:$w, pane_target:$p, dead:true, tag:"dead"}'
  exit 0
fi

# Read window flags
flags_line=$(tmux list-windows -t "${TARGET%:*}" \
  -F '#{window_name}|#{window_bell_flag}|#{window_activity_flag}|#{window_silence_flag}' 2>/dev/null \
  | awk -F'|' -v w="${TARGET#*:}" '$1 == w {print; exit}')

bell=$(awk -F'|' '{print $2}' <<< "$flags_line")
activity=$(awk -F'|' '{print $3}' <<< "$flags_line")
silence=$(awk -F'|' '{print $4}' <<< "$flags_line")

# Capture and classify
buf=$(tmux capture-pane -t "$PANE_TARGET" "${CAPTURE_ARGS[@]}" 2>/dev/null | strip_osc_leak || echo "")
capture_hash=$(printf '%s' "$buf" | sha256sum | awk '{print "sha256:"$1}')
tag=$(printf '%s' "$buf" | "$SCRIPT_DIR/prompt-classify" 2>/dev/null || echo "idle")

jq -n \
  --arg window "$TARGET" \
  --arg pane "$PANE_TARGET" \
  --argjson bell "$([ "${bell:-0}" = "1" ] && echo true || echo false)" \
  --argjson activity "$([ "${activity:-0}" = "1" ] && echo true || echo false)" \
  --argjson silence "$([ "${silence:-0}" = "1" ] && echo true || echo false)" \
  --arg tag "$tag" \
  --arg capture_hash "$capture_hash" \
  '{
    window: $window,
    pane_target: $pane,
    bell: $bell,
    activity: $activity,
    silence: $silence,
    tag: $tag,
    capture_hash: $capture_hash
  }'
