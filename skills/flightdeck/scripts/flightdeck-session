#!/usr/bin/env bash
# First-class Flightdeck session launcher/attacher for non-issue panes.
# Uses tmux windows only (never split panes) and records TrackedEntry rows
# through pane-registry init-entry.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# vstack#213 trust model (CWE-829, rounds 2/3) for FLIGHTDECK_DAEMON_BIN
# and FLIGHTDECK_PANE_REGISTRY_BIN.
#
# Both env vars cause external binaries to be invoked for daemon
# lifecycle and tracked-entry queries. A hostile override could
# misroute wake-arming, mask the daemon stop call, or impersonate the
# registry. They are intended strictly for tests and developer
# iteration; production operators should leave them unset.
#
# We enforce a minimal sanity gate via validate_override_bin:
#   1. Must be an absolute path.
#   2. Must exist and be executable.
# Both checks fail-closed with a clear stderr message.
#
# We deliberately stop short of stat-ing ownership / group/world-write
# bits / setuid because the same shim mechanism is used by every test
# in tests/parity/flightdeck-session.test.ts that lives under a
# per-test temp dir. Adding those checks here without a test-time
# opt-out would force every test to flip a bypass env var. The
# tradeoff is documented in ENV.md so production operators understand
# the trust boundary.
validate_override_bin() {
  local name="$1" value="$2"
  [[ -n "$value" ]] || return 0
  if [[ "$value" != /* ]]; then
    echo "Error: $name must be an absolute path: $value" >&2
    exit 2
  fi
  if [[ ! -x "$value" ]]; then
    echo "Error: $name not executable: $value" >&2
    exit 2
  fi
}
validate_override_bin FLIGHTDECK_PANE_REGISTRY_BIN "${FLIGHTDECK_PANE_REGISTRY_BIN:-}"
validate_override_bin FLIGHTDECK_DAEMON_BIN "${FLIGHTDECK_DAEMON_BIN:-}"

# vstack#213 round-2: test-only override for the canonical pane-registry
# binary. Production callers leave it unset and we use the script-local
# trampoline; tests inject a shim path to exercise registry-probe
# failures inside ensure_daemon_for_session. Trust model: see
# validate_override_bin block above.
PANE_REGISTRY="${FLIGHTDECK_PANE_REGISTRY_BIN:-$SCRIPT_DIR/pane-registry}"

# vstack#213: allow tests / operators to swap in a custom daemon
# binary (matches the existing FLIGHTDECK_DASHBOARD_BIN escape hatch).
# Trust model: see validate_override_bin block above.
FLIGHTDECK_DAEMON_BIN="${FLIGHTDECK_DAEMON_BIN:-$SCRIPT_DIR/flightdeck-daemon}"

# shellcheck source=lib/pane-env.sh
source "$SCRIPT_DIR/lib/pane-env.sh"
# shellcheck source=lib/pi-bridge-paths.sh
source "$SCRIPT_DIR/lib/pi-bridge-paths.sh"

ACTIVE_RUN_ROLLBACK_ARMED=0
ACTIVE_RUN_ROLLBACK_ID=""
ACTIVE_RUN_ROLLBACK_SESSION=""

active_run_arm_rollback() {
  ACTIVE_RUN_ROLLBACK_ARMED=1
  ACTIVE_RUN_ROLLBACK_ID="$1"
  ACTIVE_RUN_ROLLBACK_SESSION="$2"
}

active_run_disarm_rollback() {
  ACTIVE_RUN_ROLLBACK_ARMED=0
  ACTIVE_RUN_ROLLBACK_ID=""
  ACTIVE_RUN_ROLLBACK_SESSION=""
}

active_run_rollback_on_exit() {
  local status=$?
  if [[ "${ACTIVE_RUN_ROLLBACK_ARMED:-0}" == "1" && -n "${ACTIVE_RUN_ROLLBACK_ID:-}" ]]; then
    ACTIVE_RUN_ROLLBACK_ARMED=0
    if ! "$SCRIPT_DIR/flightdeck-state" run terminate "$ACTIVE_RUN_ROLLBACK_ID" --tmux-session "$ACTIVE_RUN_ROLLBACK_SESSION" >/dev/null 2>&1; then
      printf 'Warning: failed to roll back newly created Flightdeck active run %s after pre-registration abort\n' "$ACTIVE_RUN_ROLLBACK_ID" >&2
    fi
  fi
  return "$status"
}
trap active_run_rollback_on_exit EXIT

usage() {
  cat >&2 <<'USAGE'
Usage:
  flightdeck-session start --session-id <ID> --title <T> --cwd <path> --harness <H> (--cmd <cmd> | --prompt <text>) [--kind adhoc|workflow|issue] [--tracker linear|github] [--github-url <url>] [--model <id>] [--effort <level>|--thinking <level>] [--after-window-id <@ID>] [--no-active-run] [--strict-discovery]
  flightdeck-session attach --pane <%PANE_ID> --harness <H> --title <T> [--session-id <ID>] [--kind adhoc|workflow|issue] [--tracker linear|github] [--github-url <url>] [--worktree <path>] [--model <id>] [--effort <level>|--thinking <level>]
  flightdeck-session detect-master-harness [--master-pane <pane>]
USAGE
  exit 2
}

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

shell_join() {
  local out="" arg quoted
  for arg in "$@"; do
    printf -v quoted '%q' "$arg"
    if [[ -z "$out" ]]; then out="$quoted"; else out+=" $quoted"; fi
  done
  printf '%s\n' "$out"
}

set_pi_discovery_error() {
  local reason="$1" mode="${2:-preserve}"
  if [[ "$mode" == "force" || -z "${PI_DISCOVERY_ERROR:-}" ]]; then
    PI_DISCOVERY_ERROR="$reason"
  fi
}

pi_bridge_call_timeout_secs() {
  printf '%s' "${PI_BRIDGE_CALL_TIMEOUT_SEC:-5}"
}

pi_bridge_call() {
  local timeout_secs out status
  PI_BRIDGE_CALL_OUTPUT=""
  timeout_secs="$(pi_bridge_call_timeout_secs)"
  set +e
  out=$(timeout --kill-after=1 "${timeout_secs}s" "$@" 2>/dev/null)
  status=$?
  set -e
  if (( status == 124 || status == 137 )); then
    set_pi_discovery_error "pi_bridge_timeout" force
    return 124
  fi
  if (( status != 0 )); then
    return "$status"
  fi
  PI_BRIDGE_CALL_OUTPUT="$out"
}

require_tmux() {
  [[ -n "${TMUX:-}" ]] || { echo "Error: flightdeck-session requires an active tmux session" >&2; exit 2; }
}

resolve_master_harness() {
  local master_pane="${1:-}" master_harness="${FLIGHTDECK_MASTER_HARNESS:-}"
  if [[ -n "$master_harness" ]]; then
    printf '%s\n' "$master_harness"
    return 0
  fi
  # Default to the harness the supervisor itself is running under so
  # daemon wake payloads and hash/stability tuning match the master.
  # Do not inspect PI_SESSION_ID/PI_BRIDGE_SOCKET here: this script
  # also stores those names for newly spawned *child* Pi panes, and
  # treating child metadata as owner metadata would mis-arm non-Pi
  # masters after a Pi launch.
  if [[ -n "${FLIGHTDECK_OWNER_HARNESS:-}" ]]; then
    master_harness="$FLIGHTDECK_OWNER_HARNESS"
  elif [[ -n "${CLAUDE_SESSION_ID:-}${CLAUDE_CODE_SESSION_ID:-}" ]]; then
    master_harness="claude"
  elif [[ -n "${OPENCODE_SESSION_ID:-}${OPENCODE_APP_INFO:-}" ]]; then
    master_harness="opencode"
  elif [[ -n "${CODEX_SESSION_ID:-}${CODEX_SANDBOX:-}" ]]; then
    master_harness="codex"
  elif [[ -n "${PI_CODING_AGENT:-}" ]]; then
    master_harness="pi"
  else
    [[ -n "$master_pane" ]] || master_pane="${TMUX_PANE:-}"
    if [[ -n "$master_pane" ]]; then
      local master_cmd=""
      master_cmd=$(tmux display-message -p -t "$master_pane" '#{pane_current_command}' 2>/dev/null || true)
      case "$master_cmd" in
        pi|pi-*) master_harness="pi" ;;
        claude|claude-*) master_harness="claude" ;;
        opencode|opencode-*) master_harness="opencode" ;;
        codex|codex-*) master_harness="codex" ;;
      esac
    fi
  fi
  printf '%s\n' "$master_harness"
}

disable_auto_rename_if_requested() {
  [[ "${FLIGHTDECK_DISABLE_AUTO_RENAME:-0}" == "1" ]] || return 0
  local pane_id="$1" window_target
  window_target=$(tmux display-message -p -t "$pane_id" '#{window_id}' 2>/dev/null || true)
  [[ -n "$window_target" ]] || window_target="$pane_id"
  if ! tmux set-window-option -t "$window_target" automatic-rename off >/dev/null 2>&1; then
    echo "Warning: failed to disable tmux automatic-rename for $window_target" >&2
  fi
}

valid_kind() {
  case "$1" in adhoc|workflow|issue) return 0 ;; *) return 1 ;; esac
}

is_llm_harness() {
  case "$1" in claude|codex|opencode|pi) return 0 ;; *) return 1 ;; esac
}

default_launch_model_for_harness() {
  case "$1" in
    claude) echo "opus[1m]" ;;
    codex) echo "gpt-5.5" ;;
    opencode) echo "openai/gpt-5.5" ;;
    pi) echo "openai-codex/gpt-5.5" ;;
    *) echo "" ;;
  esac
}

default_launch_effort_for_harness() {
  case "$1" in
    claude) echo "max" ;;
    codex|opencode|pi) echo "xhigh" ;;
    *) echo "" ;;
  esac
}

validate_model_value() {
  local model="$1"
  [[ "$model" != *$'\n'* && "$model" != *$'\r'* ]] || { echo "Error: --model must be a single-line value" >&2; exit 2; }
}

validate_effort_value() {
  local harness="$1" effort="$2"
  [[ -z "$effort" ]] && return 0
  case "$harness" in
    claude)
      case "$effort" in
        low|medium|high|xhigh|max) return 0 ;;
        *) echo "Error: invalid --effort for claude: $effort (expected low|medium|high|xhigh|max)" >&2; exit 2 ;;
      esac
      ;;
    codex|pi|opencode)
      case "$effort" in
        minimal|low|medium|high|xhigh|max|off) return 0 ;;
        *) echo "Error: invalid --effort/--thinking for $harness: $effort (expected minimal|low|medium|high|xhigh|max|off)" >&2; exit 2 ;;
      esac
      ;;
    *)
      case "$effort" in
        minimal|low|medium|high|xhigh|max|off) return 0 ;;
        *) echo "Error: invalid --effort/--thinking: $effort (expected minimal|low|medium|high|xhigh|max|off)" >&2; exit 2 ;;
      esac
      ;;
  esac
}

normalize_openai_effort() {
  case "$1" in
    max) echo "xhigh" ;;
    minimal) echo "low" ;;
    *) echo "$1" ;;
  esac
}

normalize_opencode_effort() {
  local effort="$1" model="$2"
  case "$effort" in
    off) echo "none" ;;
    minimal) echo "low" ;;
    max)
      case "$model" in
        openai/*|opencode/*|*gpt*|*codex*) echo "xhigh" ;;
        *) echo "max" ;;
      esac
      ;;
    *) echo "$effort" ;;
  esac
}

resolve_effort_for_harness() {
  local harness="$1" effort="$2" model="${3:-}"
  [[ -n "$effort" ]] || return 0
  case "$harness" in
    codex|pi) normalize_openai_effort "$effort" ;;
    opencode) normalize_opencode_effort "$effort" "$model" ;;
    *) echo "$effort" ;;
  esac
}

json_argv() {
  jq -nc '$ARGS.positional' --args -- "$@"
}

resolve_harness_bin() {
  local harness="$1" bin
  case "$harness" in
    pi) pi_resolve_pi_bin || { echo "Error: pi binary not found" >&2; return 1; } ;;
    claude|codex|opencode)
      bin=$(type -P "$harness" 2>/dev/null || true)
      [[ -n "$bin" && -x "$bin" ]] || { echo "Error: $harness binary not found" >&2; return 1; }
      echo "$bin"
      ;;
    *) echo "Error: --prompt launch does not support --harness $harness" >&2; return 1 ;;
  esac
}

validate_opencode_model() {
  local bin="$1" model="$2" out
  [[ -n "$model" ]] || return 0
  [[ "${FLIGHTDECK_OPENCODE_VALIDATE_MODEL:-1}" != "0" ]] || return 0
  if ! out=$("$bin" models 2>/dev/null); then
    echo "Error: opencode models failed; cannot validate --model $model" >&2
    return 1
  fi
  if ! awk -v model="$model" '
    { for (i = 1; i <= NF; i++) { tok = $i; gsub(/^[[:space:]|│,;]+|[[:space:]|│,;]+$/, "", tok); if (tok == model) found = 1 } }
    END { exit found ? 0 : 1 }
  ' <<< "$out"; then
    echo "Error: opencode model is not configured: $model" >&2
    return 1
  fi
}

prepare_launch_metadata() {
  local harness="$1" kind="$2" mode="$3" requested_model="$4" requested_effort="$5"
  local model="" effort="" model_source="" effort_source="" default_model default_effort

  LAUNCH_MODEL=""; LAUNCH_EFFORT=""; LAUNCH_REQUESTED_MODEL=""; LAUNCH_REQUESTED_EFFORT=""
  LAUNCH_MODEL_SOURCE=""; LAUNCH_EFFORT_SOURCE=""; LAUNCH_REASONING_STATUS=""; LAUNCH_UNSUPPORTED_REASON=""; LAUNCH_ARGV_JSON=""

  if [[ -n "$requested_model" ]]; then
    model="$requested_model"; model_source="explicit"; LAUNCH_REQUESTED_MODEL="$requested_model"
  elif [[ -n "${FLIGHTDECK_LAUNCH_MODEL:-}" ]]; then
    model="$FLIGHTDECK_LAUNCH_MODEL"; model_source="env"; LAUNCH_REQUESTED_MODEL="$FLIGHTDECK_LAUNCH_MODEL"
  elif [[ "$mode" == "prompt" ]] && is_llm_harness "$harness"; then
    default_model=$(default_launch_model_for_harness "$harness")
    if [[ -n "$default_model" ]]; then model="$default_model"; model_source="auto"; fi
  fi

  if [[ -n "$requested_effort" ]]; then
    effort="$requested_effort"; effort_source="explicit"; LAUNCH_REQUESTED_EFFORT="$requested_effort"
  elif [[ -n "${FLIGHTDECK_LAUNCH_EFFORT:-}" ]]; then
    effort="$FLIGHTDECK_LAUNCH_EFFORT"; effort_source="env"; LAUNCH_REQUESTED_EFFORT="$FLIGHTDECK_LAUNCH_EFFORT"
  elif [[ "$mode" == "prompt" ]] && is_llm_harness "$harness"; then
    default_effort=$(default_launch_effort_for_harness "$harness")
    if [[ -n "$default_effort" ]]; then effort="$default_effort"; effort_source="auto"; fi
  fi

  validate_model_value "$model"
  validate_effort_value "$harness" "$effort"

  if is_llm_harness "$harness"; then
    if [[ "$effort" == "off" ]]; then
      LAUNCH_MODEL="$model"
      LAUNCH_EFFORT=""
      LAUNCH_MODEL_SOURCE="$model_source"
      LAUNCH_EFFORT_SOURCE="$effort_source"
      LAUNCH_REASONING_STATUS="unsupported"
      LAUNCH_UNSUPPORTED_REASON="effort explicitly disabled with --effort off"
    elif [[ "$harness" == "opencode" && -n "$effort" ]]; then
      LAUNCH_MODEL="$model"
      LAUNCH_EFFORT=""
      LAUNCH_MODEL_SOURCE="$model_source"
      LAUNCH_EFFORT_SOURCE="$effort_source"
      LAUNCH_REASONING_STATUS="unsupported"
      LAUNCH_UNSUPPORTED_REASON="OpenCode top-level effort/variant is not supported by flightdeck-session; model only"
    elif [[ "$mode" == "prompt" ]]; then
      LAUNCH_MODEL="$model"
      LAUNCH_EFFORT=$(resolve_effort_for_harness "$harness" "$effort" "$model")
      LAUNCH_MODEL_SOURCE="$model_source"
      LAUNCH_EFFORT_SOURCE="$effort_source"
      LAUNCH_REASONING_STATUS="configured"
    elif [[ -n "$model" || -n "$effort" ]]; then
      LAUNCH_MODEL="$model"
      LAUNCH_EFFORT=$(resolve_effort_for_harness "$harness" "$effort" "$model")
      LAUNCH_MODEL_SOURCE="$model_source"
      LAUNCH_EFFORT_SOURCE="$effort_source"
      LAUNCH_REASONING_STATUS="recorded"
      LAUNCH_UNSUPPORTED_REASON="custom --cmd launch; caller-provided command must include matching harness model/effort argv"
    else
      LAUNCH_REASONING_STATUS="unsupported"
      LAUNCH_UNSUPPORTED_REASON="custom --cmd or attached LLM session; model/effort not discoverable by flightdeck-session"
    fi
  else
    LAUNCH_REASONING_STATUS="not-applicable"
    LAUNCH_UNSUPPORTED_REASON="harness $harness is not an LLM harness"
  fi
}

dashboard_after_window_id_unsupported() {
  local stderr_text="$1"
  [[ "$stderr_text" == *"unexpected argument '--after-window-id'"* ]] && return 0
  [[ "$stderr_text" == *'unexpected argument "--after-window-id"'* ]] && return 0
  [[ "$stderr_text" == *"unrecognized option '--after-window-id'"* ]] && return 0
  [[ "$stderr_text" == *"unknown option --after-window-id"* ]] && return 0
  return 1
}

ensure_dashboard_launched() {
  local entry_id="$1" after_window_id="${2:-}" dashboard_bin err rc args state_file window_id stderr_text unsupported_stderr=""
  DASHBOARD_WINDOW_ID=""
  [[ "$entry_id" != "flightdeck-dashboard" ]] || return 0
  [[ "${FLIGHTDECK_DASHBOARD:-1}" != "0" ]] || return 0
  [[ "${FLIGHTDECK_DASHBOARD_LAUNCHING:-0}" != "1" ]] || return 0
  dashboard_bin="${FLIGHTDECK_DASHBOARD_BIN:-$SCRIPT_DIR/flightdeck-dashboard}"
  [[ -x "$dashboard_bin" ]] || { printf 'Warning: flightdeck dashboard launch skipped; executable not found: %s\n' "$dashboard_bin" >&2; return 0; }
  err=$(mktemp -t flightdeck-dashboard-launch.XXXXXX)
  rc=0
  args=(launch)
  [[ -n "$after_window_id" ]] && args+=(--after-window-id "$after_window_id")
  FLIGHTDECK_DASHBOARD_LAUNCHING=1 "$dashboard_bin" "${args[@]}" 2>"$err" || rc=$?
  stderr_text=$(cat "$err" 2>/dev/null || true)
  if (( rc != 0 )) && [[ -n "$after_window_id" ]] && dashboard_after_window_id_unsupported "$stderr_text"; then
    unsupported_stderr="$stderr_text"
    printf 'Warning: flightdeck dashboard launch does not support --after-window-id; retrying without window positioning\n' >&2
    : >"$err"
    rc=0
    FLIGHTDECK_DASHBOARD_LAUNCHING=1 "$dashboard_bin" launch 2>"$err" || rc=$?
    stderr_text=$(cat "$err" 2>/dev/null || true)
  fi
  if (( rc != 0 )) && [[ -n "$unsupported_stderr" ]]; then
    printf '%s\n' "$unsupported_stderr" >&2
  fi
  [[ -n "$stderr_text" ]] && printf '%s\n' "$stderr_text" >&2
  rm -f "$err"
  if (( rc != 0 )); then
    printf 'Warning: flightdeck dashboard launch failed before launching %s (rc=%s); continuing without dashboard\n' "$entry_id" "$rc" >&2
    return 0
  fi
  state_file=$("$SCRIPT_DIR/flightdeck-state" path 2>/dev/null || true)
  if [[ -n "$state_file" && -f "$state_file" ]]; then
    window_id=$(jq -r '.entries["flightdeck-dashboard"].window_id // empty' "$state_file" 2>/dev/null || true)
    if [[ -n "$window_id" && "$window_id" != "null" ]]; then
      DASHBOARD_WINDOW_ID="$window_id"
    fi
  fi
  return 0
}

should_skip_active_run_ensure() {
  local entry_id="$1" explicit_skip="${2:-0}"
  [[ "$entry_id" == "flightdeck-dashboard" ]] && return 0
  [[ "${FLIGHTDECK_DASHBOARD_LAUNCHING:-0}" == "1" ]] && return 0
  [[ "${FLIGHTDECK_SKIP_ACTIVE_RUN:-0}" == "1" ]] && return 0
  [[ "${FLIGHTDECK_NO_ACTIVE_RUN:-0}" == "1" ]] && return 0
  [[ "$explicit_skip" == "1" ]] && return 0
  return 1
}

capture_pane_meta() {
  local target="$1"
  CAPTURE_PANE_ID=$(tmux display-message -t "$target" -p '#{pane_id}' 2>/dev/null || true)
  [[ -n "$CAPTURE_PANE_ID" ]] || { echo "Error: unable to resolve pane id for $target" >&2; exit 2; }
  CAPTURE_WINDOW_ID=$(tmux display-message -t "$CAPTURE_PANE_ID" -p '#{window_id}' 2>/dev/null || true)
  CAPTURE_WINDOW_INDEX=$(tmux display-message -t "$CAPTURE_PANE_ID" -p '#{window_index}' 2>/dev/null || true)
  CAPTURE_PANE_INDEX=$(tmux display-message -t "$CAPTURE_PANE_ID" -p '#{pane_index}' 2>/dev/null || true)
  CAPTURE_PANE_CWD=$(tmux display-message -t "$CAPTURE_PANE_ID" -p '#{pane_current_path}' 2>/dev/null || true)
  CAPTURE_SESSION=$(tmux display-message -p '#S' 2>/dev/null || echo unknown)
  CAPTURE_PANE_TARGET="${CAPTURE_SESSION}:${CAPTURE_WINDOW_INDEX}.${CAPTURE_PANE_INDEX}"
}

pi_state_for_pid() {
  local pid="$1" bridge_bin state
  bridge_bin=$(pi_resolve_bridge_bin 2>/dev/null) || { set_pi_discovery_error "pi_bridge_not_found"; return 1; }
  if ! pi_bridge_call "$bridge_bin" state --pid "$pid"; then
    [[ "${PI_DISCOVERY_ERROR:-}" == "pi_bridge_timeout" ]] || set_pi_discovery_error "pi_bridge_state_unavailable"
    return 1
  fi
  state="$PI_BRIDGE_CALL_OUTPUT"
  [[ -n "$state" ]] || { set_pi_discovery_error "pi_bridge_state_unavailable"; return 1; }
  PI_BRIDGE_PID="$pid"
  PI_BRIDGE_SOCKET=$(jq -r '.data.socketPath // .data.socket // ""' <<< "$state" 2>/dev/null || echo "")
  PI_SESSION_ID=$(jq -r '.data.sessionId // .data.session_id // ""' <<< "$state" 2>/dev/null || echo "")
  if [[ -z "$PI_BRIDGE_SOCKET" || -z "$PI_SESSION_ID" ]]; then
    set_pi_discovery_error "pi_bridge_partial_metadata"
  fi
  [[ -n "$PI_BRIDGE_SOCKET" || -n "$PI_SESSION_ID" ]]
}

pi_snapshot_pids_checked() {
  local bridge_bin out pids jq_status
  PI_SNAPSHOT_PIDS="[]"
  bridge_bin=$(pi_resolve_bridge_bin 2>/dev/null) || {
    set_pi_discovery_error "pi_snapshot_failed" force
    PI_SNAPSHOT_ERROR="pi_bridge_not_found"
    return 1
  }
  if ! pi_bridge_call "$bridge_bin" list --json; then
    PI_SNAPSHOT_ERROR="${PI_DISCOVERY_ERROR:-pi_bridge_list_failed}"
    set_pi_discovery_error "pi_snapshot_failed" force
    return 1
  fi
  out="$PI_BRIDGE_CALL_OUTPUT"
  set +e
  pids=$(jq -c 'if type == "array" then map(.pid) | map(select(. != null)) else error("not array") end' <<< "$out" 2>/dev/null)
  jq_status=$?
  set -e
  if (( jq_status != 0 )); then
    PI_SNAPSHOT_ERROR="pi_bridge_malformed_json"
    set_pi_discovery_error "pi_snapshot_failed" force
    return 1
  fi
  PI_SNAPSHOT_PIDS="$pids"
}

warn_pi_snapshot_failure() {
  local reason="${PI_SNAPSHOT_ERROR:-unknown}"
  printf 'Warning: pre-launch pi snapshot failed (%s); cwd-only discovery is unreliable.\n' "$reason" >&2
}

pi_discover_pid_bounded() {
  local wt_path="$1" timeout_secs="${2:-30}" pre_pids_json="${3:-[]}" bridge_bin abs_wt deadline out pid jq_status
  PI_DISCOVERED_PID=""
  bridge_bin=$(pi_resolve_bridge_bin 2>/dev/null) || { set_pi_discovery_error "pi_bridge_not_found"; return 1; }
  abs_wt=$(cd "$wt_path" && pwd)
  deadline=$((SECONDS + timeout_secs))
  while (( SECONDS < deadline )); do
    if ! pi_bridge_call "$bridge_bin" list --json; then
      [[ "${PI_DISCOVERY_ERROR:-}" == "pi_bridge_timeout" ]] || set_pi_discovery_error "pi_bridge_list_failed"
      return 1
    fi
    out="$PI_BRIDGE_CALL_OUTPUT"
    set +e
    pid=$(jq -r --arg dir "$abs_wt" --argjson pre "$pre_pids_json" '
      (if type == "array" then . else [] end)
      | map(select((.cwd // "") == $dir))
      | map(select(.pid as $p | ($pre // []) | index($p) | not))
      | sort_by(.startedAt // .started_at // 0)
      | last
      | (.pid // empty)
    ' <<< "$out" 2>/dev/null)
    jq_status=$?
    set -e
    if (( jq_status != 0 )); then
      set_pi_discovery_error "pi_bridge_malformed_json"
      return 1
    fi
    if [[ -n "$pid" && "$pid" != "null" ]]; then
      PI_DISCOVERED_PID="$pid"
      return 0
    fi
    sleep 0.2
  done
  set_pi_discovery_error "pi_bridge_discovery_timeout"
  return 1
}

pi_discover_after_launch() {
  local cwd="$1" pre_pids="$2" timeout_secs="${PI_BRIDGE_DISCOVERY_TIMEOUT:-30}" pid existing_error
  existing_error="${PI_DISCOVERY_ERROR:-}"
  PI_BRIDGE_PID=""; PI_BRIDGE_SOCKET=""; PI_SESSION_ID=""; PI_DISCOVERY_ERROR="$existing_error"
  if ! pi_resolve_bridge_bin >/dev/null 2>&1; then
    set_pi_discovery_error "pi_bridge_not_found"
    return 1
  fi
  if pi_discover_pid_bounded "$cwd" "$timeout_secs" "$pre_pids"; then
    pid="$PI_DISCOVERED_PID"
    pi_state_for_pid "$pid" || return 1
  else
    set_pi_discovery_error "pi_bridge_discovery_timeout"
    return 1
  fi
}

pi_discover_for_pane() {
  local pane="$1" pane_pid bridge_bin out line
  PI_BRIDGE_PID=""; PI_BRIDGE_SOCKET=""; PI_SESSION_ID=""; PI_DISCOVERY_ERROR=""
  pane_pid=$(tmux display-message -t "$pane" -p '#{pane_pid}' 2>/dev/null || true)
  [[ -n "$pane_pid" ]] || { set_pi_discovery_error "pi_pane_pid_unavailable"; return 1; }
  bridge_bin=$(pi_resolve_bridge_bin 2>/dev/null) || { set_pi_discovery_error "pi_bridge_not_found"; return 1; }
  if ! pi_bridge_call "$bridge_bin" list --json --pid "$pane_pid"; then
    if [[ "${PI_DISCOVERY_ERROR:-}" == "pi_bridge_timeout" ]]; then
      return 1
    fi
    if ! pi_bridge_call "$bridge_bin" list --json; then
      [[ "${PI_DISCOVERY_ERROR:-}" == "pi_bridge_timeout" ]] || set_pi_discovery_error "pi_bridge_list_failed"
      return 1
    fi
  fi
  out="$PI_BRIDGE_CALL_OUTPUT"
  [[ -n "${out//[[:space:]]/}" ]] || { set_pi_discovery_error "pi_bridge_empty_output"; return 1; }
  line=$(jq -r --arg pid "$pane_pid" '
    (if type == "array" then . else (.data.instances // .instances // []) end)
    | map(select((.pid | tostring) == $pid))
    | .[0] // {}
    | [(.pid // ""), (.socketPath // .socket // ""), (.sessionId // .session_id // "")]
    | @tsv
  ' <<< "$out" 2>/dev/null || echo "")
  PI_BRIDGE_PID=$(awk -F'\t' '{print $1}' <<< "$line")
  PI_BRIDGE_SOCKET=$(awk -F'\t' '{print $2}' <<< "$line")
  PI_SESSION_ID=$(awk -F'\t' '{print $3}' <<< "$line")
  if [[ -z "$PI_BRIDGE_PID" && -z "$PI_BRIDGE_SOCKET" && -z "$PI_SESSION_ID" ]]; then
    set_pi_discovery_error "pi_bridge_no_instance_for_pane_pid"
    return 1
  fi
  if [[ -z "$PI_BRIDGE_SOCKET" || -z "$PI_SESSION_ID" ]]; then
    set_pi_discovery_error "pi_bridge_partial_metadata"
  fi
  [[ -n "$PI_BRIDGE_PID" || -n "$PI_BRIDGE_SOCKET" || -n "$PI_SESSION_ID" ]]
}

warn_pi_discovery_error() {
  local context="$1"
  [[ -n "${PI_DISCOVERY_ERROR:-}" ]] || return 0
  printf 'Warning: pi-bridge metadata discovery failed during %s (%s); registering degraded entry.\n' "$context" "$PI_DISCOVERY_ERROR" >&2
}

build_prompt_cmd() {
  local harness="$1" prompt="$2" session_id="${3:-session}" out_var="${4:-}" tmp_var="${5:-}" bin ext_path bridge_args=() harness_args=() argv_record=() prompt_mode="positional"
  if ! bin=$(resolve_harness_bin "$harness"); then
    return 1
  fi
  case "$harness" in
    pi)
      ext_path=$(pi_resolve_bridge_extension 2>/dev/null || echo "")
      [[ -n "$ext_path" ]] && bridge_args=(-e "$ext_path")
      harness_args=("$bin")
      [[ -n "${LAUNCH_MODEL:-}" ]] && harness_args+=(--model "$LAUNCH_MODEL")
      [[ -n "${LAUNCH_EFFORT:-}" ]] && harness_args+=(--thinking "$LAUNCH_EFFORT")
      harness_args+=("${bridge_args[@]}")
      ;;
    claude)
      harness_args=("$bin")
      [[ -n "${LAUNCH_MODEL:-}" ]] && harness_args+=(--model "$LAUNCH_MODEL")
      [[ -n "${LAUNCH_EFFORT:-}" ]] && harness_args+=(--effort "$LAUNCH_EFFORT")
      ;;
    codex)
      harness_args=("$bin")
      [[ -n "${LAUNCH_MODEL:-}" ]] && harness_args+=(-m "$LAUNCH_MODEL")
      [[ -n "${LAUNCH_EFFORT:-}" ]] && harness_args+=(-c "model_reasoning_effort=$LAUNCH_EFFORT")
      ;;
    opencode)
      validate_opencode_model "$bin" "${LAUNCH_MODEL:-}" || return 1
      harness_args=("$bin")
      [[ -n "${LAUNCH_MODEL:-}" ]] && harness_args+=(--model "$LAUNCH_MODEL")
      prompt_mode="opencode-prompt-flag"
      ;;
    *)
      echo "Error: --prompt launch does not support --harness $harness" >&2
      return 1
      ;;
  esac
  local runtime_dir prompt_dir safe_session prompt_file inner_cmd prompt_arg body built_cmd
  runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
  prompt_dir="$runtime_dir/flightdeck"
  if ! mkdir -p "$prompt_dir"; then
    echo "Error: failed to create Pi prompt temp dir: $prompt_dir" >&2
    return 1
  fi
  chmod 700 "$prompt_dir" 2>/dev/null || true
  safe_session=$(printf '%s' "$session_id" | tr -c 'A-Za-z0-9_.-' '_')
  if ! prompt_file=$(mktemp "$prompt_dir/prompt-${safe_session}-XXXXXX.txt"); then
    echo "Error: failed to create Pi prompt temp file under: $prompt_dir" >&2
    return 1
  fi
  if ! printf '%s' "$prompt" > "$prompt_file"; then
    echo "Error: failed to write Pi prompt temp file: $prompt_file" >&2
    rm -f "$prompt_file"
    return 1
  fi
  inner_cmd=$(shell_join env FLIGHTDECK_MANAGED=1 FLIGHTDECK_CHILD_PANE=1 "FLIGHTDECK_ENTRY_ID=${session_id}" "${harness_args[@]}")
  prompt_arg=$(shell_join "$prompt_file")
  argv_record=("${harness_args[@]}")
  if [[ "$prompt_mode" == "opencode-prompt-flag" ]]; then
    argv_record+=(--prompt "<prompt>")
    body="IFS= read -r -d '' p < ${prompt_arg} || true; rm -f ${prompt_arg}; exec ${inner_cmd} --prompt \"\$p\""
  else
    argv_record+=("<prompt>")
    body="IFS= read -r -d '' p < ${prompt_arg} || true; rm -f ${prompt_arg}; exec ${inner_cmd} \"\$p\""
  fi
  LAUNCH_ARGV_JSON=$(json_argv "${argv_record[@]}")
  built_cmd=$(shell_join bash -c "$body")
  if [[ -n "$out_var" ]]; then
    printf -v "$out_var" '%s' "$built_cmd"
  else
    printf '%s\n' "$built_cmd"
  fi
  if [[ -n "$tmp_var" ]]; then
    printf -v "$tmp_var" '%s' "$prompt_file"
  fi
}

register_entry() {
  local entry_id="$1" title="$2" kind="$3" cwd="$4" window_index="$5" harness="$6" pane_id="$7" pane_target="$8" window_id="$9" launch_cmd="${10}" worktree="${11:-}" pr="${12:-}" branch="${13:-}" tracker="${14:-linear}" github_url="${15:-}"
  local args=(init-entry "$entry_id" --title "$title" --kind "$kind" --cwd "$cwd" --window "$window_index" --harness "$harness" --pane-id "$pane_id" --pane-target "$pane_target" --window-id "$window_id" --window-index "$window_index")
  [[ -n "$worktree" ]] && args+=(--worktree "$worktree")
  [[ -n "$pr" ]] && args+=(--pr "$pr")
  [[ -n "$branch" ]] && args+=(--branch "$branch")
  [[ -n "$tracker" ]] && args+=(--tracker "$tracker")
  [[ -n "$github_url" ]] && args+=(--github-url "$github_url")
  [[ -n "$launch_cmd" ]] && args+=(--launch-cmd "$launch_cmd")
  [[ -n "${LAUNCH_MODEL:-}" ]] && args+=(--launch-model "$LAUNCH_MODEL")
  [[ -n "${LAUNCH_EFFORT:-}" ]] && args+=(--launch-effort "$LAUNCH_EFFORT")
  [[ -n "${LAUNCH_REQUESTED_MODEL:-}" ]] && args+=(--launch-requested-model "$LAUNCH_REQUESTED_MODEL")
  [[ -n "${LAUNCH_REQUESTED_EFFORT:-}" ]] && args+=(--launch-requested-effort "$LAUNCH_REQUESTED_EFFORT")
  [[ -n "${LAUNCH_MODEL:-}" ]] && args+=(--launch-resolved-model "$LAUNCH_MODEL")
  [[ -n "${LAUNCH_EFFORT:-}" ]] && args+=(--launch-resolved-effort "$LAUNCH_EFFORT")
  [[ -n "${LAUNCH_MODEL_SOURCE:-}" ]] && args+=(--launch-model-source "$LAUNCH_MODEL_SOURCE")
  [[ -n "${LAUNCH_EFFORT_SOURCE:-}" ]] && args+=(--launch-effort-source "$LAUNCH_EFFORT_SOURCE")
  [[ -n "${LAUNCH_REASONING_STATUS:-}" ]] && args+=(--launch-reasoning-status "$LAUNCH_REASONING_STATUS")
  [[ -n "${LAUNCH_UNSUPPORTED_REASON:-}" ]] && args+=(--launch-unsupported-reason "$LAUNCH_UNSUPPORTED_REASON")
  [[ -n "${LAUNCH_ARGV_JSON:-}" ]] && args+=(--launch-argv-json "$LAUNCH_ARGV_JSON")
  [[ -n "${PI_BRIDGE_PID:-}" ]] && args+=(--pi-bridge-pid "$PI_BRIDGE_PID")
  [[ -n "${PI_BRIDGE_SOCKET:-}" ]] && args+=(--pi-bridge-socket "$PI_BRIDGE_SOCKET")
  [[ -n "${PI_SESSION_ID:-}" ]] && args+=(--pi-session-id "$PI_SESSION_ID")
  [[ -n "${PI_DISCOVERY_ERROR:-}" ]] && args+=(--discovery-error "$PI_DISCOVERY_ERROR")
  "$PANE_REGISTRY" "${args[@]}"
  # vstack#214: refresh pane coords / window names for every tracked entry
  # after a fresh registration. tmux may have renumbered prior windows as
  # a side effect of spawning this one, and `init-entry` only refreshes
  # the new row's snapshot. Re-running the refresh here heals stale
  # pane_target / window / window_index for sibling entries within one
  # spawn instead of waiting for the daemon's reconcile tick (default
  # FD_RECONCILE_INTERVAL_SEC=5). The daemon tick remains the durable
  # repair path, so a failed refresh here is non-fatal — but it MUST be
  # visible to operator/daemon logs (no silent swallow) so a partial
  # repair isn't mistaken for a clean spawn.
  local fd_refresh_err_file
  fd_refresh_err_file=$(mktemp -t fd-refresh-err.XXXXXX 2>/dev/null) || fd_refresh_err_file=""
  local fd_refresh_stdout fd_refresh_rc=0
  if [[ -n "$fd_refresh_err_file" ]]; then
    fd_refresh_stdout=$("$PANE_REGISTRY" refresh-window-names 2>"$fd_refresh_err_file") || fd_refresh_rc=$?
  else
    fd_refresh_stdout=$("$PANE_REGISTRY" refresh-window-names 2>&1) || fd_refresh_rc=$?
  fi
  if (( fd_refresh_rc != 0 )); then
    printf 'flightdeck-session: post-register refresh-window-names failed (rc=%d, entry_id=%s)\n' "$fd_refresh_rc" "$entry_id" >&2
    [[ -n "$fd_refresh_stdout" ]] && printf '%s\n' "$fd_refresh_stdout" >&2
    if [[ -n "$fd_refresh_err_file" && -s "$fd_refresh_err_file" ]]; then
      cat "$fd_refresh_err_file" >&2
    fi
  else
    if [[ -n "$fd_refresh_err_file" && -s "$fd_refresh_err_file" ]]; then
      cat "$fd_refresh_err_file" >&2
    fi
    if [[ -n "$fd_refresh_stdout" ]] && command -v jq >/dev/null 2>&1; then
      local fd_refresh_warning_count
      fd_refresh_warning_count=$(printf '%s' "$fd_refresh_stdout" | jq -r '(.warnings // []) | length' 2>/dev/null || printf '0')
      if [[ "$fd_refresh_warning_count" =~ ^[0-9]+$ ]] && (( fd_refresh_warning_count > 0 )); then
        printf 'flightdeck-session: post-register refresh-window-names returned %d warning(s) (entry_id=%s):\n' "$fd_refresh_warning_count" "$entry_id" >&2
        printf '%s\n' "$fd_refresh_stdout" | jq -r '.warnings[] | "  - id=\(.id // "-") reason=\(.reason) message=\(.message)"' >&2 || printf '%s\n' "$fd_refresh_stdout" >&2
      fi
    fi
  fi
  [[ -n "$fd_refresh_err_file" ]] && rm -f "$fd_refresh_err_file"
}

# vstack#101: capture git branch at spawn time. Silent when not a git
# repo or HEAD is detached (output starts with HEAD or is empty).
capture_git_branch() {
  local dir="$1" out
  out=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
  case "$out" in
    ""|HEAD|HEAD*) printf '%s' "" ;;
    *) printf '%s' "$out" ;;
  esac
}

# vstack#100: build the per-session child-pane env. Includes the canonical
# FLIGHTDECK_MANAGED + FLIGHTDECK_CHILD_PANE signals and binds
# FLIGHTDECK_ENTRY_ID=<session_id> so wrapped tools inside the pane
# (linear/github wrappers, activity emitter) attribute their events to
# the originating entry without each caller passing --entry-id explicitly.
flightdeck_session_pane_env_str() {
  local entry_id="$1"
  flightdeck_shell_join env FLIGHTDECK_MANAGED=1 FLIGHTDECK_CHILD_PANE=1 "FLIGHTDECK_ENTRY_ID=${entry_id}"
}

# vstack#227: archive-stale-state is now handled inside the run-store.
# ensureActiveRun detects `terminated == true` / `all panes missing`
# active runs and rotates them into a fresh durable run; the old
# project-local `tmp/flightdeck-state-<S>.json.archive` rename is gone.
# This wrapper is preserved as a thin shim so the existing call sites
# continue to compile, but it no longer does any work itself.
archive_stale_state_if_needed() {
  return 0
}

ensure_active_run_for_session() {
  if [[ "${FLIGHTDECK_SKIP_ACTIVE_RUN:-0}" == "1" || "${FLIGHTDECK_NO_ACTIVE_RUN:-0}" == "1" ]]; then
    return 0
  fi
  local session_name ensure_json action run_id
  session_name=$(tmux display-message -p '#S' 2>/dev/null || true)
  [[ -n "$session_name" ]] || { echo "Error: unable to resolve tmux session for Flightdeck run" >&2; exit 2; }
  if ! ensure_json=$("$SCRIPT_DIR/flightdeck-state" run ensure --tmux-session "$session_name"); then
    echo "Error: failed to create or reuse Flightdeck active run" >&2
    exit 2
  fi
  action=$(jq -r '.action // empty' <<< "$ensure_json" 2>/dev/null || true)
  run_id=$(jq -r '.active.run_id // .metadata.run_id // empty' <<< "$ensure_json" 2>/dev/null || true)
  case "$action" in
    created|created-after-terminated|created-after-stale)
      if [[ -z "$run_id" ]]; then
        echo "Error: flightdeck-state run ensure returned creation action without active run id" >&2
        exit 2
      fi
      active_run_arm_rollback "$run_id" "$session_name"
      ;;
  esac
}

# vstack#213: leave a daemon whose subscriber set matches the current
# tracked entries before flightdeck-session returns.
#
# Invariant: callers must not rely on daemons started by earlier sessions.
# Reconciliation is best-effort safety net, not the primary mechanism for
# picking up new panes.
#
# Algorithm (round-1 simplification — health is the single source of truth):
#   1. If FLIGHTDECK_ENSURE_DAEMON=0 (test override) or
#      FLIGHTDECK_SKIP_ACTIVE_RUN/FLIGHTDECK_NO_ACTIVE_RUN=1 (dashboard
#      self-launch), skip silently.
#   2. Resolve master pane from $TMUX_PANE. Warn-and-skip when missing.
#   3. Compute the alive inner panes + harnesses from the live tracked
#      entries (registry filter ∩ tmux liveness). Warn-and-skip when
#      the probes fail or no panes are tracked.
#   4. Run `flightdeck-daemon health`. The TS implementation already
#      compares meta against live tracked entries (pane-registry
#      inner-live-json) and reports a definitive `staleness` field, so
#      the bash side trusts it.
#   5. If health says fresh AND `master_pane_id` + `master_harness`
#      match the current master, leave the daemon alone. Otherwise
#      stop + start.
#   6. After respawn, if `start` rc=1 (possible lock-race), re-run
#      health and only declare a benign race when staleness is now
#      `fresh` and both master pane + harness match; surface
#      daemon-respawn-failed otherwise.
ensure_daemon_for_session() {
  [[ "${FLIGHTDECK_ENSURE_DAEMON:-1}" == "1" ]] || return 0
  [[ "${FLIGHTDECK_SKIP_ACTIVE_RUN:-0}" == "1" || "${FLIGHTDECK_NO_ACTIVE_RUN:-0}" == "1" ]] && return 0
  if [[ -z "${TMUX:-}" ]]; then
    printf 'Warning: flightdeck-session ensure_daemon: no $TMUX session; skipping daemon arm\n' >&2
    return 0
  fi
  local session_name
  if ! session_name=$(tmux display-message -p '#S' 2>/dev/null) || [[ -z "$session_name" ]]; then
    printf 'Warning: flightdeck-session ensure_daemon: tmux display-message #S failed; skipping daemon arm\n' >&2
    return 0
  fi
  local master_pane="${TMUX_PANE:-}"
  if [[ -z "$master_pane" ]]; then
    master_pane=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
  fi
  if [[ -z "$master_pane" ]]; then
    printf 'Warning: flightdeck-session ensure_daemon: cannot resolve master pane (TMUX_PANE empty, tmux display-message failed); session=%s; skipping daemon arm\n' "$session_name" >&2
    return 0
  fi

  # Filter the flightdeck-dashboard self-entry out of the daemon's
  # --inner list. The dashboard is a tracking shell, not a watch
  # target.
  local registry_json inner_pairs_json registry_err registry_rc=0
  registry_err=$(mktemp -t flightdeck-session-registry.XXXXXX)
  registry_json=$("$PANE_REGISTRY" list --format json 2>"$registry_err") || registry_rc=$?
  if (( registry_rc != 0 )); then
    local _rerr; _rerr=$(cat "$registry_err" 2>/dev/null || true)
    rm -f "$registry_err"
    printf 'Warning: flightdeck-session ensure_daemon: pane-registry list rc=%s session=%s; skipping daemon arm. stderr=%s\n' "$registry_rc" "$session_name" "${_rerr:-(none)}" >&2
    return 0
  fi
  rm -f "$registry_err"
  inner_pairs_json=$(jq -c '
    (if type == "array" then . else [] end)
    | map(select((.id // "") != "flightdeck-dashboard"))
    | map(select((.pane_id // "") | length > 0))
    | map({pane_id: .pane_id, harness: (.harness // "")})
  ' <<< "$registry_json" 2>/dev/null || echo "[]")
  local inner_panes inner_harnesses
  inner_panes=$(jq -r '. | map(.pane_id) | join(",")' <<< "$inner_pairs_json" 2>/dev/null || true)
  inner_harnesses=$(jq -r '. | map(.harness) | join(",")' <<< "$inner_pairs_json" 2>/dev/null || true)
  if [[ -z "$inner_panes" ]]; then
    # No tracked entries beyond the dashboard → no daemon needed yet.
    return 0
  fi

  # Filter to the panes that are actually alive in tmux right now so
  # we don't pass dead ids to flightdeck-daemon start. tmux liveness
  # failures are non-fatal but visible.
  local alive_panes alive_tmp alive_rc=0 inner_panes_live="" inner_harnesses_live=""
  alive_tmp=$(mktemp -t flightdeck-session-alive.XXXXXX)
  alive_panes=$(tmux list-panes -a -F '#{pane_id}' 2>"$alive_tmp") || alive_rc=$?
  if (( alive_rc != 0 )); then
    local _aerr; _aerr=$(cat "$alive_tmp" 2>/dev/null || true)
    rm -f "$alive_tmp"
    printf 'Warning: flightdeck-session ensure_daemon: tmux list-panes -a rc=%s session=%s; skipping daemon arm. stderr=%s\n' "$alive_rc" "$session_name" "${_aerr:-(none)}" >&2
    return 0
  fi
  rm -f "$alive_tmp"
  local _pane _harness idx=0 panes_arr harnesses_arr
  IFS=',' read -r -a panes_arr <<< "$inner_panes"
  IFS=',' read -r -a harnesses_arr <<< "$inner_harnesses"
  for _pane in "${panes_arr[@]}"; do
    _harness="${harnesses_arr[$idx]:-}"
    idx=$((idx + 1))
    [[ -n "$_pane" ]] || continue
    # P4 hardening: only accept canonical tmux pane ids before passing
    # them to grep and the daemon argv.
    [[ "$_pane" =~ ^%[0-9]+$ ]] || continue
    if grep -Fxq -- "$_pane" <<<"$alive_panes"; then
      if [[ -z "$inner_panes_live" ]]; then
        inner_panes_live="$_pane"
        inner_harnesses_live="$_harness"
      else
        inner_panes_live+=",$_pane"
        inner_harnesses_live+=",$_harness"
      fi
    fi
  done
  if [[ -z "$inner_panes_live" ]]; then
    printf 'Warning: flightdeck-session ensure_daemon: no live tracked panes after tmux filter session=%s tracked=%s; skipping daemon arm\n' "$session_name" "$inner_panes" >&2
    return 0
  fi

  local master_harness
  master_harness=$(resolve_master_harness "$master_pane")

  # Run health and trust its staleness output. cmdHealth (vstack#213
  # round-1) computes staleness against the live tracked-entry set via
  # pane-registry inner-live-json, so we don't redo subscriber/harness
  # comparison in bash.
  local health_output health_err health_status=0 staleness="" current_master="" current_master_harness=""
  health_err=$(mktemp -t flightdeck-session-health.XXXXXX)
  health_output=$("$FLIGHTDECK_DAEMON_BIN" health --session "$session_name" 2>"$health_err") || health_status=$?
  if (( health_status == 0 )); then
    staleness=$(awk -F= '/^staleness=/{print $2; exit}' <<<"$health_output")
    current_master=$(awk -F= '/^master_pane_id=/{print $2; exit}' <<<"$health_output")
    current_master_harness=$(awk -F= '/^master_harness=/{print $2; exit}' <<<"$health_output")
    # If master pane diverged the daemon is wired to the wrong
    # supervisor; treat as stale regardless of staleness field.
    if [[ "$staleness" == "fresh" && -n "$current_master" && "$current_master" != "$master_pane" ]]; then
      staleness="stale-master"
    fi
    if [[ "$staleness" == "fresh" && -n "$master_harness" ]]; then
      if [[ -z "$current_master_harness" || "$current_master_harness" == "(unknown)" ]]; then
        staleness="stale-master-harness"
      elif [[ "$current_master_harness" != "$master_harness" ]]; then
        staleness="stale-master-harness"
      fi
    fi
  fi
  rm -f "$health_err"

  local need_respawn=0
  if (( health_status == 0 )); then
    [[ "$staleness" == "fresh" ]] || need_respawn=1
  else
    # health rc=1 means no-daemon; rc=2 is preflight error. Either way
    # we need to start fresh.
    need_respawn=1
  fi

  (( need_respawn == 1 )) || return 0

  # vstack#213 round-3: hold the stop stderr capture until after the
  # subsequent start completes so a daemon-respawn-failed message can
  # surface both the stop-side and the start-side context. Operators
  # investigating a failed respawn need both: the start-side stderr
  # alone hides the case where stop refused (exit 3 / safety) and the
  # start then races a daemon that the helper failed to terminate.
  local stop_err="" stop_rc=0
  if (( health_status == 0 )); then
    stop_err=$(mktemp -t flightdeck-daemon-stop.XXXXXX)
    "$FLIGHTDECK_DAEMON_BIN" stop --session "$session_name" >/dev/null 2>"$stop_err" || stop_rc=$?
    if (( stop_rc != 0 && stop_rc != 1 )); then
      local _serr; _serr=$(cat "$stop_err" 2>/dev/null || true)
      printf 'Warning: flightdeck-session ensure_daemon: flightdeck-daemon stop rc=%s session=%s; daemon may still be running with stale --inner. stderr=%s\n' "$stop_rc" "$session_name" "${_serr:-(none)}" >&2
    fi
    # Deliberately do NOT rm "$stop_err" yet — keep it for the
    # daemon-respawn-failed branch below.
  fi

  local start_args=(start --session "$session_name" --master "$master_pane" --inner "$inner_panes_live" --inner-harnesses "$inner_harnesses_live")
  [[ -n "$master_harness" ]] && start_args+=(--master-harness "$master_harness")
  local start_err start_rc=0
  start_err=$(mktemp -t flightdeck-daemon-start.XXXXXX)
  "$FLIGHTDECK_DAEMON_BIN" "${start_args[@]}" >/dev/null 2>"$start_err" || start_rc=$?
  if (( start_rc == 4 )); then
    master_pane="${TMUX_PANE:-}"
    if [[ -z "$master_pane" ]]; then
      master_pane=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
    fi
    if [[ -n "$master_pane" ]]; then
      start_args=(start --session "$session_name" --master "$master_pane" --inner "$inner_panes_live" --inner-harnesses "$inner_harnesses_live")
      [[ -n "$master_harness" ]] && start_args+=(--master-harness "$master_harness")
      start_rc=0
      "$FLIGHTDECK_DAEMON_BIN" "${start_args[@]}" >/dev/null 2>"$start_err" || start_rc=$?
    fi
  fi
  if (( start_rc == 1 )); then
    # Possible lock race: confirm by re-running health and treating
    # this as benign only when the running daemon now reports
    # staleness=fresh AND master_pane_id matches the current
    # supervisor. A still-stale daemon, a different master, or any
    # other refusal must surface daemon-respawn-failed so the
    # operator sees the stop+start stderr instead of a silent
    # "raced" log line that masks the real issue.
    local verify_output="" verify_status=0 verify_staleness="" verify_master="" verify_master_harness=""
    verify_output=$("$FLIGHTDECK_DAEMON_BIN" health --session "$session_name" 2>/dev/null) || verify_status=$?
    if (( verify_status == 0 )); then
      verify_staleness=$(awk -F= '/^staleness=/{print $2; exit}' <<<"$verify_output")
      verify_master=$(awk -F= '/^master_pane_id=/{print $2; exit}' <<<"$verify_output")
      verify_master_harness=$(awk -F= '/^master_harness=/{print $2; exit}' <<<"$verify_output")
    fi
    if [[ "$verify_staleness" == "fresh" && "$verify_master" == "$master_pane" && ( -z "$master_harness" || "$verify_master_harness" == "$master_harness" ) ]]; then
      printf 'flightdeck-session: ensure_daemon: daemon-respawn-raced session=%s (verified fresh + master=%s harness=%s after lock-race)\n' "$session_name" "$master_pane" "${master_harness:-(unknown)}" >&2
      start_rc=0
    fi
  fi
  if (( start_rc != 0 )); then
    printf 'Warning: flightdeck-session ensure_daemon: daemon-respawn-failed session=%s start_rc=%s stop_rc=%s; watch loop will retry\n' "$session_name" "$start_rc" "$stop_rc" >&2
    if [[ -n "$stop_err" && -s "$stop_err" ]]; then
      printf '%s\n' '--- flightdeck-daemon stop stderr ---' >&2
      cat "$stop_err" >&2
    fi
    if [[ -s "$start_err" ]]; then
      printf '%s\n' '--- flightdeck-daemon start stderr ---' >&2
      cat "$start_err" >&2
    fi
  fi
  rm -f "$start_err"
  if [[ -n "$stop_err" ]]; then rm -f "$stop_err"; fi
  return 0
}


cmd_start() {
  require_tmux
  local session_id="" title="" cwd="" harness="" cmd="" prompt="" kind="adhoc" worktree="" pr="" strict_discovery=0 skip_active_run=0 model_override="" effort_override="" tracker="linear" github_url="" after_window_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session-id) session_id="$2"; shift 2 ;;
      --session-id=*) session_id="${1#--session-id=}"; shift ;;
      --title) title="$2"; shift 2 ;;
      --title=*) title="${1#--title=}"; shift ;;
      --cwd) cwd="$2"; shift 2 ;;
      --cwd=*) cwd="${1#--cwd=}"; shift ;;
      --harness) harness="$2"; shift 2 ;;
      --harness=*) harness="${1#--harness=}"; shift ;;
      --cmd) cmd="$2"; shift 2 ;;
      --cmd=*) cmd="${1#--cmd=}"; shift ;;
      --prompt) prompt="$2"; shift 2 ;;
      --prompt=*) prompt="${1#--prompt=}"; shift ;;
      --model) model_override="$2"; shift 2 ;;
      --model=*) model_override="${1#--model=}"; shift ;;
      --effort|--thinking) effort_override="$2"; shift 2 ;;
      --effort=*|--thinking=*) effort_override="${1#*=}"; shift ;;
      --kind) kind="$2"; shift 2 ;;
      --kind=*) kind="${1#--kind=}"; shift ;;
      --tracker) tracker="$2"; shift 2 ;;
      --tracker=*) tracker="${1#--tracker=}"; shift ;;
      --github-url|--github-issue-url) github_url="$2"; shift 2 ;;
      --github-url=*|--github-issue-url=*) github_url="${1#*=}"; shift ;;
      --after-window-id) after_window_id="$2"; shift 2 ;;
      --after-window-id=*) after_window_id="${1#--after-window-id=}"; shift ;;
      --worktree) worktree="$2"; shift 2 ;;
      --worktree=*) worktree="${1#--worktree=}"; shift ;;
      --pr) pr="$2"; shift 2 ;;
      --pr=*) pr="${1#--pr=}"; shift ;;
      --strict-discovery) strict_discovery=1; shift ;;
      --no-active-run|--no-run) skip_active_run=1; shift ;;
      --help|-h) usage ;;
      *) echo "Unknown flag: $1" >&2; usage ;;
    esac
  done
  [[ -n "$session_id" && -n "$title" && -n "$cwd" && -n "$harness" ]] || usage
  valid_kind "$kind" || { echo "Error: invalid --kind: $kind" >&2; exit 2; }
  [[ "$tracker" == "linear" || "$tracker" == "github" ]] || { echo "Error: invalid --tracker: $tracker" >&2; exit 2; }
  if [[ "$kind" == "issue" && "$tracker" == "github" ]]; then
    [[ "$session_id" =~ ^[0-9]+$ ]] || { echo "Error: github tracker requires numeric --session-id" >&2; exit 2; }
    [[ -n "$github_url" ]] || { echo "Error: github tracker requires --github-url" >&2; exit 2; }
  fi
  [[ -n "$cmd" || -n "$prompt" ]] || { echo "Error: start requires --cmd or --prompt" >&2; exit 2; }
  [[ -z "$cmd" || -z "$prompt" ]] || { echo "Error: --cmd and --prompt are mutually exclusive" >&2; exit 2; }

  local abs_cwd launch_cmd pre_pids="[]" prompt_tmpfile=""
  PI_DISCOVERY_ERROR=""
  PI_SNAPSHOT_ERROR=""
  PI_SNAPSHOT_PIDS="[]"
  abs_cwd=$(cd "$cwd" && pwd)
  # Durable active-run wiring must not create a user run for the dashboard app's
  # self-entry. The dashboard launcher passes --no-active-run and marker envs;
  # real supervised sessions continue through run ensure below.
  if should_skip_active_run_ensure "$session_id" "$skip_active_run"; then
    export FLIGHTDECK_SKIP_ACTIVE_RUN=1
    export FLIGHTDECK_NO_ACTIVE_RUN=1
  fi
  archive_stale_state_if_needed
  ensure_active_run_for_session
  if [[ -n "$prompt" ]]; then
    prepare_launch_metadata "$harness" "$kind" "prompt" "$model_override" "$effort_override"
  else
    prepare_launch_metadata "$harness" "$kind" "cmd" "$model_override" "$effort_override"
  fi
  if [[ -n "$prompt" ]]; then
    case "$harness" in
      pi)
        if ! pi_snapshot_pids_checked; then
          warn_pi_snapshot_failure
          if (( strict_discovery == 1 )); then
            echo "Error: --strict-discovery refusing Pi launch after pre-launch snapshot failure" >&2
            exit 2
          fi
        fi
        pre_pids="$PI_SNAPSHOT_PIDS"
        ;;
      claude|codex|opencode) ;;
      *) echo "Error: --prompt launch does not support --harness $harness; use --cmd for $harness" >&2; exit 2 ;;
    esac
    if ! build_prompt_cmd "$harness" "$prompt" "$session_id" launch_cmd prompt_tmpfile; then
      exit 2
    fi
  else
    launch_cmd="$(flightdeck_session_pane_env_str "$session_id") $cmd"
  fi

  local insert_after_window_id="$after_window_id" dashboard_after_window_id="" current_window_id="" pane_id dashboard_rc
  if [[ -z "$insert_after_window_id" ]]; then
    current_window_id=$(tmux display-message -p '#{window_id}' 2>/dev/null || true)
    dashboard_after_window_id="$current_window_id"
  else
    dashboard_after_window_id="$insert_after_window_id"
  fi
  set +e
  ensure_dashboard_launched "$session_id" "$dashboard_after_window_id"
  dashboard_rc=$?
  set -e
  if (( dashboard_rc != 0 )); then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    exit "$dashboard_rc"
  fi
  [[ -n "${DASHBOARD_WINDOW_ID:-}" ]] && insert_after_window_id="$DASHBOARD_WINDOW_ID"

  local new_window_args=(-d -P -F '#{pane_id}' -n "$title" -c "$abs_cwd")
  if [[ -n "$insert_after_window_id" ]]; then
    new_window_args=(-a -t "$insert_after_window_id" "${new_window_args[@]}")
  fi
  local new_window_err new_window_rc new_window_stderr insert_desc
  new_window_err=$(mktemp -t flightdeck-session-new-window.XXXXXX)
  set +e
  pane_id=$(tmux new-window "${new_window_args[@]}" 2>"$new_window_err")
  new_window_rc=$?
  set -e
  new_window_stderr=$(cat "$new_window_err" 2>/dev/null || true)
  rm -f "$new_window_err"
  insert_desc="default"
  [[ -n "$insert_after_window_id" ]] && insert_desc="after-window-id=$insert_after_window_id"
  if (( new_window_rc != 0 )); then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    printf 'Error: tmux new-window failed (rc=%s, %s, title=%s)\n' "$new_window_rc" "$insert_desc" "$title" >&2
    [[ -n "$new_window_stderr" ]] && printf '%s\n' "$new_window_stderr" >&2
    exit 2
  fi
  if [[ -z "$pane_id" ]]; then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    printf 'Error: tmux new-window returned empty pane id (%s, title=%s)\n' "$insert_desc" "$title" >&2
    exit 2
  fi
  disable_auto_rename_if_requested "$pane_id"
  if ! tmux send-keys -t "$pane_id" "clear" Enter; then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    echo "Error: tmux send-keys failed during pane clear" >&2
    exit 2
  fi
  if ! tmux send-keys -t "$pane_id" -l "$launch_cmd"; then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    echo "Error: tmux send-keys failed during launch command" >&2
    exit 2
  fi
  if ! tmux send-keys -t "$pane_id" Enter; then
    [[ -n "$prompt_tmpfile" ]] && rm -f "$prompt_tmpfile"
    echo "Error: tmux send-keys failed during launch submit" >&2
    exit 2
  fi
  prompt_tmpfile=""
  capture_pane_meta "$pane_id"

  if [[ -n "$prompt" && "$harness" == "pi" ]]; then
    pi_discover_after_launch "$abs_cwd" "$pre_pids" || true
    warn_pi_discovery_error "start"
  else
    PI_BRIDGE_PID=""; PI_BRIDGE_SOCKET=""; PI_SESSION_ID=""; PI_DISCOVERY_ERROR=""
  fi

  [[ -n "$worktree" ]] || [[ "$kind" != "issue" ]] || worktree="$abs_cwd"
  local branch
  branch=$(capture_git_branch "$abs_cwd")
  # Persist the requested cwd as canonical. Interactive harnesses can still
  # report a stale tmux pane_current_path during launch (for example the
  # parent shell's cwd before `exec pi`), but all activity/PR/worktree
  # attribution should bind to the caller-selected working directory.
  register_entry "$session_id" "$title" "$kind" "$abs_cwd" "$CAPTURE_WINDOW_INDEX" "$harness" "$CAPTURE_PANE_ID" "$CAPTURE_PANE_TARGET" "$CAPTURE_WINDOW_ID" "$launch_cmd" "$worktree" "$pr" "$branch" "$tracker" "$github_url"
  active_run_disarm_rollback
  ensure_daemon_for_session
  printf 'flightdeck-session: started %s kind=%s pane_id=%s target=%s\n' "$session_id" "$kind" "$CAPTURE_PANE_ID" "$CAPTURE_PANE_TARGET"
}

cmd_attach() {
  require_tmux
  local pane="" harness="" title="" kind="adhoc" session_id="" model_override="" effort_override="" tracker="linear" github_url="" worktree=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --pane=*) pane="${1#--pane=}"; shift ;;
      --harness) harness="$2"; shift 2 ;;
      --harness=*) harness="${1#--harness=}"; shift ;;
      --title) title="$2"; shift 2 ;;
      --title=*) title="${1#--title=}"; shift ;;
      --kind) kind="$2"; shift 2 ;;
      --kind=*) kind="${1#--kind=}"; shift ;;
      --tracker) tracker="$2"; shift 2 ;;
      --tracker=*) tracker="${1#--tracker=}"; shift ;;
      --github-url|--github-issue-url) github_url="$2"; shift 2 ;;
      --github-url=*|--github-issue-url=*) github_url="${1#*=}"; shift ;;
      --worktree) worktree="$2"; shift 2 ;;
      --worktree=*) worktree="${1#--worktree=}"; shift ;;
      --model) model_override="$2"; shift 2 ;;
      --model=*) model_override="${1#--model=}"; shift ;;
      --effort|--thinking) effort_override="$2"; shift 2 ;;
      --effort=*|--thinking=*) effort_override="${1#*=}"; shift ;;
      --session-id) session_id="$2"; shift 2 ;;
      --session-id=*) session_id="${1#--session-id=}"; shift ;;
      --help|-h) usage ;;
      *) echo "Unknown flag: $1" >&2; usage ;;
    esac
  done
  [[ -n "$pane" && -n "$harness" && -n "$title" ]] || usage
  valid_kind "$kind" || { echo "Error: invalid --kind: $kind" >&2; exit 2; }
  [[ "$tracker" == "linear" || "$tracker" == "github" ]] || { echo "Error: invalid --tracker: $tracker" >&2; exit 2; }
  if [[ "$kind" == "issue" && "$tracker" == "github" ]]; then
    [[ -n "$session_id" && "$session_id" =~ ^[0-9]+$ ]] || { echo "Error: github tracker requires numeric --session-id" >&2; exit 2; }
    [[ -n "$github_url" ]] || { echo "Error: github tracker requires --github-url" >&2; exit 2; }
  fi
  tmux list-panes -t "$pane" >/dev/null 2>&1 || { echo "Error: pane not found: $pane" >&2; exit 1; }
  archive_stale_state_if_needed
  ensure_active_run_for_session
  capture_pane_meta "$pane"
  if [[ "$harness" == "pi" ]]; then
    pi_discover_for_pane "$CAPTURE_PANE_ID" || true
    warn_pi_discovery_error "attach"
  else
    PI_BRIDGE_PID=""; PI_BRIDGE_SOCKET=""; PI_SESSION_ID=""; PI_DISCOVERY_ERROR=""
  fi
  if [[ -z "$session_id" ]]; then
    if [[ -n "${PI_SESSION_ID:-}" ]]; then
      session_id="$PI_SESSION_ID"
    else
      session_id="pane-${CAPTURE_PANE_ID#%}"
    fi
  fi
  prepare_launch_metadata "$harness" "$kind" "attach" "$model_override" "$effort_override"
  local branch=""
  [[ -n "$CAPTURE_PANE_CWD" ]] && branch=$(capture_git_branch "$CAPTURE_PANE_CWD")
  [[ -z "$worktree" && "$kind" == "issue" ]] && worktree="$CAPTURE_PANE_CWD"
  register_entry "$session_id" "$title" "$kind" "$CAPTURE_PANE_CWD" "$CAPTURE_WINDOW_INDEX" "$harness" "$CAPTURE_PANE_ID" "$CAPTURE_PANE_TARGET" "$CAPTURE_WINDOW_ID" "" "$worktree" "" "$branch" "$tracker" "$github_url"
  active_run_disarm_rollback
  ensure_dashboard_launched "$session_id"
  ensure_daemon_for_session
  printf 'flightdeck-session: attached %s kind=%s pane_id=%s target=%s\n' "$session_id" "$kind" "$CAPTURE_PANE_ID" "$CAPTURE_PANE_TARGET"
}

cmd_detect_master_harness() {
  local master_pane="${TMUX_PANE:-}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --master-pane) master_pane="$2"; shift 2 ;;
      --master-pane=*) master_pane="${1#--master-pane=}"; shift ;;
      --help|-h) echo "Usage: flightdeck-session detect-master-harness [--master-pane <pane>]"; exit 0 ;;
      *) echo "Unknown flag: $1" >&2; echo "Usage: flightdeck-session detect-master-harness [--master-pane <pane>]" >&2; exit 2 ;;
    esac
  done
  resolve_master_harness "$master_pane"
}

ACTION="${1:-start}"
case "$ACTION" in
  start) shift || true; cmd_start "$@" ;;
  attach) shift || true; cmd_attach "$@" ;;
  detect-master-harness) shift || true; cmd_detect_master_harness "$@" ;;
  --help|-h|help) usage ;;
  *) cmd_start "$@" ;;
esac
