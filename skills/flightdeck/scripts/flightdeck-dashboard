#!/usr/bin/env bash
# Trampoline for the Rust flightdeck-dashboard implementation.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export FLIGHTDECK_SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CRATE_DIR="$SCRIPT_DIR/../lib/flightdeck-dashboard"
BIN="$CRATE_DIR/target/release/flightdeck-dashboard"

# A prebuilt binary may pre-date source changes (the Rust dashboard is
# rebuilt locally; vstack#234+ moved live state under ~/.vstack/ and
# requires a fresh binary). When cargo is available and any source file
# under Cargo.{toml,lock} or src/ is newer than the binary, rebuild
# before exec'ing. Set FLIGHTDECK_DASHBOARD_NO_REBUILD=1 to skip the
# staleness check (e.g. for offline / no-cargo environments where the
# binary is intentionally pinned).
if [[ -x "$BIN" && "${FLIGHTDECK_DASHBOARD_NO_REBUILD:-0}" != "1" ]] \
   && command -v cargo >/dev/null 2>&1; then
  if [[ -n "$(find "$CRATE_DIR/Cargo.toml" "$CRATE_DIR/Cargo.lock" "$CRATE_DIR/src" -newer "$BIN" -print -quit 2>/dev/null)" ]]; then
    echo "flightdeck-dashboard: source newer than $BIN; rebuilding (set FLIGHTDECK_DASHBOARD_NO_REBUILD=1 to skip)" >&2
    rebuild_log=$(mktemp -t flightdeck-dashboard-rebuild.XXXXXX)
    if cargo build --release --quiet --manifest-path "$CRATE_DIR/Cargo.toml" >"$rebuild_log" 2>&1; then
      rm -f "$rebuild_log"
    else
      echo "flightdeck-dashboard: warning: rebuild failed; using existing $BIN (set FLIGHTDECK_DASHBOARD_NO_REBUILD=1 to skip)" >&2
      cat "$rebuild_log" >&2
      rm -f "$rebuild_log"
    fi
  fi
fi

if [[ -x "$BIN" ]]; then
  exec "$BIN" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --release --manifest-path "$CRATE_DIR/Cargo.toml" -- "$@"
fi

echo "Error: flightdeck-dashboard binary not found at $BIN and cargo is not on PATH" >&2
exit 1
