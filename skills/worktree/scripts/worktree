#!/bin/bash
# Portable git worktree manager
# Usage: worktree create|list|remove|cleanup|path|exists|check|push|fix-links|codex-setup|codex-branch|codex-cleanup [ID] [options]
#   create options:
#     --base BRANCH   Checkout an existing remote branch into the worktree
#     --from REF      Create a new branch starting from REF (branch, tag, or commit)
#     --pr NUMBER     Look up the branch from a PR number (implies --base)
#
# Layout: project/main (repo) + project/trees/{id} (worktrees by default)
# Config: reads .env, vstack.settings.toml, then .env.local for optional settings (see below)
#
# vstack.settings.toml [env] and .env/.env.local config vars:
#   WORKTREE_BASE_DIR        - parent directory for worktrees (relative to main checkout or absolute; default: ../trees)
#   WORKTREE_DEFAULT_BRANCH  - default branch name (auto-detected if unset, fallback: main)
#   WORKTREE_SYMLINKS        - space-separated paths to symlink from main into worktrees
#   WORKTREE_RELATIVE_SYMLINKS - space-separated path=target symlinks created inside worktrees
#   WORKTREE_COPIES          - space-separated paths to copy from main into worktrees
#   WORKTREE_MKDIRS          - space-separated paths to mkdir -p inside each worktree (e.g. tmp scratch dirs)
#   BOT_NAME                 - git user.name for worktree commits
#   BOT_EMAIL                - git user.email for worktree commits
#   BOT_SIGNING_KEY          - SSH signing key path
#   BOT_REMOTE_NAME          - remote name for push (default: origin)
#   BOT_REMOTE_URL           - URL for bot remote (added on create if set)

set -euo pipefail

# Resolve PROJECT_ROOT via git (works at any depth, inside worktrees too)
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "$PROJECT_ROOT" ]]; then
  echo "Error: Not inside a git repository" >&2
  exit 1
fi

# If inside a worktree, resolve to the main repo root
_git_common_dir=$(git -C "$PROJECT_ROOT" rev-parse --git-common-dir 2>/dev/null)
if [[ "$_git_common_dir" != ".git" && -n "$_git_common_dir" ]]; then
  PROJECT_ROOT="$(cd "$PROJECT_ROOT" && cd "$(dirname "$_git_common_dir")" && pwd)"
fi

# Load project config and secrets. .env.local still wins for compatibility.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/vstack-env.sh
source "$SCRIPT_DIR/lib/vstack-env.sh"
vstack_load_project_env "$PROJECT_ROOT"

GITHUB_AUTH_LIB="$SCRIPT_DIR/../../github/scripts/lib/gh-auth.sh"
if [[ -f "$GITHUB_AUTH_LIB" ]]; then
  # shellcheck source=../../github/scripts/lib/gh-auth.sh
  source "$GITHUB_AUTH_LIB"
fi

git_with_github_https_auth() {
  if declare -F vstack_github_git >/dev/null 2>&1; then
    vstack_github_git "$@"
  else
    git "$@"
  fi
}

strip_trailing_slashes() {
  local path="$1"
  while [[ "$path" != "/" && "$path" == */ ]]; do
    path="${path%/}"
  done
  printf '%s\n' "$path"
}

resolve_worktree_base_dir() {
  local raw="${WORKTREE_BASE_DIR:-}"
  if [[ -z "$raw" ]]; then
    printf '%s\n' "$(dirname "$PROJECT_ROOT")/trees"
    return
  fi

  if [[ "$raw" == "~" ]]; then
    raw="${HOME:?WORKTREE_BASE_DIR uses ~ but HOME is not set}"
  elif [[ "$raw" == "~/"* ]]; then
    raw="${HOME:?WORKTREE_BASE_DIR uses ~ but HOME is not set}/${raw#~/}"
  fi

  raw="$(strip_trailing_slashes "$raw")"

  local path
  if [[ "$raw" == /* ]]; then
    path="$raw"
  else
    path="$PROJECT_ROOT/$raw"
  fi

  [[ "$path" == "/" ]] && { printf '/\n'; return; }

  local parent name
  parent="$(dirname "$path")"
  name="$(basename "$path")"
  if [[ -d "$parent" ]]; then
    printf '%s/%s\n' "$(cd "$parent" && pwd -P)" "$name"
  else
    printf '%s\n' "$path"
  fi
}

# Layout: project/main (repo) + configured parent dir (worktrees)
TREES_DIR="$(resolve_worktree_base_dir)"

# Detect default branch (configurable, auto-detected, fallback: main)
detect_default_branch() {
  if [[ -n "${WORKTREE_DEFAULT_BRANCH:-}" ]]; then
    echo "$WORKTREE_DEFAULT_BRANCH"
    return
  fi
  local detected
  detected=$(git -C "$PROJECT_ROOT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
  echo "${detected:-main}"
}
DEFAULT_BRANCH="$(detect_default_branch)"

# Fetch origin to update tracking refs. Never touches local branches.
fetch_origin() {
  git_with_github_https_auth -C "$PROJECT_ROOT" fetch origin >/dev/null 2>&1 || true
}

worktree_path() {
  echo "$TREES_DIR/$(echo "$1" | tr '[:upper:]' '[:lower:]')"
}

issue_branch_name() {
  echo "$1" | tr '[:upper:]' '[:lower:]'
}

current_checkout_path_for_issue() {
  local issue="$1"
  local expected_branch current_root current_branch
  expected_branch="$(issue_branch_name "$issue")"
  current_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$current_root" ]] || return 1
  current_branch="$(git -C "$current_root" branch --show-current 2>/dev/null || true)"
  [[ -n "$current_branch" && "$current_branch" == "$expected_branch" ]] || return 1
  printf '%s\n' "$current_root"
}

# Symlink a path from main repo into worktree (handles tracked dirs with assume-unchanged)
# Idempotently append a worktree-relative path to the COMMON git-dir's
# info/exclude so git treats the symlink we lay down as ignored content.
# Required because .gitignore patterns with a trailing slash (e.g. `.agents/`)
# match only real directories, not symlinks pointing at directories — without
# the exclude entry, `git status` lists the symlink as untracked and
# `worktree remove` refuses without --force. Git does NOT consult the
# per-worktree git-dir's info/exclude; only the common dir's is read
# (https://git-scm.com/docs/gitignore#_pattern_format), so we must write
# there. The shared exclude file is harmless for the main checkout because
# the same paths exist there as real gitignored directories.
exclude_from_worktree_index() {
  local wt="$1" path="$2"
  [[ -z "$path" ]] && return 0
  local common_dir info_exclude
  common_dir="$(git -C "$wt" rev-parse --git-common-dir 2>/dev/null)" || return 0
  info_exclude="$common_dir/info/exclude"
  mkdir -p "$(dirname "$info_exclude")"
  grep -qxF "$path" "$info_exclude" 2>/dev/null || echo "$path" >> "$info_exclude"
}

symlink_into_worktree() {
  local src="$PROJECT_ROOT/$1"
  local dst="$2/$1"

  # Every worktree-local symlink we create should be invisible to git status
  # in this worktree, regardless of whether the source dir has tracked files.
  exclude_from_worktree_index "$2" "$1"

  if [[ -f "$src" ]]; then
    # File symlink — if the path is tracked in the worktree (common before a
    # project stops committing harness config files), mark it assume-unchanged
    # so replacing it with a symlink does not leave a noisy typechange.
    if git -C "$2" ls-files --error-unmatch "$1" >/dev/null 2>&1; then
      git -C "$2" update-index --assume-unchanged "$1" 2>/dev/null || true
    fi
    mkdir -p "$(dirname "$dst")"
    ln -sf "$src" "$dst"
  elif [[ -d "$src" ]]; then
    # Directory symlink — if tracked by git, also mark files assume-unchanged
    # to prevent staging issues. (The exclude entry above already hides the
    # symlink itself; assume-unchanged covers the path's tracked contents.)
    if git -C "$2" ls-files "$1/" 2>/dev/null | grep -q .; then
      git -C "$2" ls-files "$1/" 2>/dev/null | \
        xargs -r git -C "$2" update-index --assume-unchanged 2>/dev/null
    fi

    # Always remove existing dir/file before symlinking — rebase can replace
    # symlinks with real directories when tracked files exist underneath
    rm -rf "$dst" 2>/dev/null
    mkdir -p "$(dirname "$dst")"
    ln -sfn "$src" "$dst"
  fi
}

# Remove symlinks created by 'create' from a worktree
remove_symlinks() {
  local wt="$1"
  # Clean configured symlinks
  for path in ${WORKTREE_SYMLINKS:-}; do
    rm -f "$wt/$path" 2>/dev/null
    # Try to clean empty parent dirs
    local parent="$(dirname "$wt/$path")"
    while [[ "$parent" != "$wt" && "$parent" != "/" ]]; do
      rmdir "$parent" 2>/dev/null || break
      parent="$(dirname "$parent")"
    done
  done
  # Clean configured relative/internal symlinks
  for spec in ${WORKTREE_RELATIVE_SYMLINKS:-}; do
    [[ "$spec" == *=* ]] || continue
    local path="${spec%%=*}"
    [[ -n "$path" ]] || continue
    rm -f "$wt/$path" 2>/dev/null
    # Try to clean empty parent dirs
    local parent="$(dirname "$wt/$path")"
    while [[ "$parent" != "$wt" && "$parent" != "/" ]]; do
      rmdir "$parent" 2>/dev/null || break
      parent="$(dirname "$parent")"
    done
  done
}

# Apply all symlinks and copies to a worktree
setup_worktree_links() {
  local wt="$1"

  # Project-configured mkdirs (run first so subsequent symlinks/copies can
  # land inside them if needed). Idempotent; ignores empty entries.
  for path in ${WORKTREE_MKDIRS:-}; do
    if [[ -n "$path" ]]; then
      mkdir -p "$wt/$path"
      exclude_from_worktree_index "$wt" "$path"
    fi
  done

  # Project-configured symlinks
  for path in ${WORKTREE_SYMLINKS:-}; do
    [[ -e "$PROJECT_ROOT/$path" ]] && symlink_into_worktree "$path" "$wt"
  done

  # Project-configured copies
  for path in ${WORKTREE_COPIES:-}; do
    if [[ -f "$PROJECT_ROOT/$path" ]]; then
      exclude_from_worktree_index "$wt" "$path"
      mkdir -p "$(dirname "$wt/$path")"
      cp "$PROJECT_ROOT/$path" "$wt/$path"
    fi
  done

  # Project-configured symlinks whose targets should resolve from inside the
  # worktree, not from the main checkout. Useful for harness pointers like
  # .claude/CLAUDE.md -> ../AGENTS.md.
  for spec in ${WORKTREE_RELATIVE_SYMLINKS:-}; do
    if [[ "$spec" != *=* ]]; then
      echo "Warning: Ignoring invalid WORKTREE_RELATIVE_SYMLINKS entry '$spec' (expected path=target)" >&2
      continue
    fi
    local path="${spec%%=*}"
    local target="${spec#*=}"
    if [[ -z "$path" || -z "$target" ]]; then
      echo "Warning: Ignoring invalid WORKTREE_RELATIVE_SYMLINKS entry '$spec' (expected path=target)" >&2
      continue
    fi
    mkdir -p "$(dirname "$wt/$path")"
    rm -rf "$wt/$path" 2>/dev/null
    ln -sfn "$target" "$wt/$path"
    exclude_from_worktree_index "$wt" "$path"
  done
}

configure_worktree_git() {
  local wt="$1"

  # Required before writing per-worktree git config. Safe to repeat.
  git -C "$PROJECT_ROOT" config extensions.worktreeConfig true 2>/dev/null || true

  # Add bot remote for agent pushes (if configured).
  if [[ -n "${BOT_REMOTE_NAME:-}" && -n "${BOT_REMOTE_URL:-}" ]]; then
    git -C "$wt" remote add "$BOT_REMOTE_NAME" "$BOT_REMOTE_URL" 2>/dev/null || true
  fi

  # Set agent git identity (if configured).
  if [[ -n "${BOT_NAME:-}" ]]; then
    git -C "$wt" config --worktree user.name "$BOT_NAME"
    git -C "$wt" config --worktree user.email "${BOT_EMAIL:-}"
    if [[ -n "${BOT_SIGNING_KEY:-}" ]]; then
      git -C "$wt" config --worktree gpg.format ssh
      git -C "$wt" config --worktree user.signingkey "$BOT_SIGNING_KEY"
      git -C "$wt" config --worktree commit.gpgsign true
    fi
  fi
}

install_worktree_dependencies() {
  local wt="$1"

  # Preserve the historical behavior for JS worktrees without blocking setup.
  if [[ -f "$wt/package.json" ]] && command -v npm >/dev/null 2>&1; then
    (
      cd "$wt" || exit 0
      npm install --no-audit --no-fund >/dev/null 2>&1
    ) &
  fi
}

setup_codex_worktree() {
  local wt="$1"

  setup_worktree_links "$wt"
  configure_worktree_git "$wt"
  install_worktree_dependencies "$wt"
}

is_git_worktree_path() {
  local wt="$1"
  [[ -f "$wt/.git" || -d "$wt/.git" ]]
}

case "${1:-}" in
  create)
    # Ensure worktreeConfig is enabled (required for per-worktree git config)
    git -C "$PROJECT_ROOT" config extensions.worktreeConfig true 2>/dev/null || true

    ISSUE="${2:?Error: create requires an issue ID}"
    shift 2
    BASE=""
    BRANCH=""
    FROM=""
    PR=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --base) BASE="$2"; shift 2 ;;
        --from) FROM="$2"; shift 2 ;;
        --pr) PR="$2"; shift 2 ;;
        *) BRANCH="$1"; shift ;;
      esac
    done
    WT_PATH="$(worktree_path "$ISSUE")"
    mkdir -p "$TREES_DIR"

    # 1. If worktree already exists at path, reuse it after updating
    if [[ -d "$WT_PATH" ]] && git -C "$WT_PATH" rev-parse --git-dir &>/dev/null; then
      fetch_origin
      CURRENT_BRANCH=$(git -C "$WT_PATH" branch --show-current 2>/dev/null)
      if [[ -n "$CURRENT_BRANCH" ]]; then
        if ! git -C "$WT_PATH" rebase "origin/$DEFAULT_BRANCH" >/dev/null 2>&1; then
          git -C "$WT_PATH" rebase --abort >/dev/null 2>&1 || true
          echo "Error: Rebase onto origin/$DEFAULT_BRANCH failed for $WT_PATH (conflicts). Resolve manually or delete worktree." >&2
          exit 1
        fi
      fi
      # Refresh setup (rebase may have replaced symlinks with tracked content)
      setup_codex_worktree "$WT_PATH"
      echo "$WT_PATH"
      exit 0
    fi

    # 1b. Orphan directory exists (no .git pointer) — clean up before fresh create
    if [[ -d "$WT_PATH" ]]; then
      echo "Warning: Removing orphan directory at $WT_PATH (not a git worktree)" >&2
      rm -rf "$WT_PATH"
      git -C "$PROJECT_ROOT" worktree prune 2>/dev/null || true
    fi

    # 2. If --from specified, create a new branch starting from that ref
    if [[ -n "$FROM" ]]; then
      fetch_origin
      BRANCH="${BRANCH:-$(echo "$ISSUE" | tr '[:upper:]' '[:lower:]')}"
      # Resolve: try origin/$FROM first (remote branch), then $FROM directly (local branch/tag/commit)
      if git -C "$PROJECT_ROOT" rev-parse --verify "origin/$FROM" &>/dev/null; then
        START_POINT="origin/$FROM"
      elif git -C "$PROJECT_ROOT" rev-parse --verify "$FROM" &>/dev/null; then
        START_POINT="$FROM"
      else
        echo "Error: Cannot resolve ref '$FROM'" >&2
        exit 1
      fi
      git -C "$PROJECT_ROOT" worktree add --no-track -b "$BRANCH" "$WT_PATH" "$START_POINT" >/dev/null 2>&1
      # Set upstream tracking if a remote branch matches the new branch name
      _REMOTE="${BOT_REMOTE_NAME:-origin}"
      if git -C "$WT_PATH" rev-parse --verify "$_REMOTE/$BRANCH" &>/dev/null; then
        git -C "$WT_PATH" branch --set-upstream-to="$_REMOTE/$BRANCH" "$BRANCH" >/dev/null 2>&1 || true
        git -C "$WT_PATH" merge --ff-only "$_REMOTE/$BRANCH" >/dev/null 2>&1 || true
      fi
      setup_codex_worktree "$WT_PATH"
      echo "$WT_PATH"
      exit 0
    fi

    # 3. If --pr specified, look up the branch from the PR (implies --base)
    if [[ -n "$PR" ]] && command -v gh &>/dev/null; then
      BASE=$(gh pr view "$PR" --json headRefName -q .headRefName 2>/dev/null)
      if [[ -z "$BASE" ]]; then
        echo "Error: Could not find branch for PR #$PR" >&2
        exit 1
      fi
    fi

    # 4. Auto-detect: check if PR exists with expected branch patterns.
    # Best-effort — if gh auth is broken (e.g. unresolved op:// token in
    # GH_TOKEN) the command-substitution would otherwise kill the script
    # under set -e and silently exit 1 with no output (#3).
    if [[ -z "$BASE" ]] && command -v gh &>/dev/null; then
      ISSUE_LOWER=$(echo "$ISSUE" | tr '[:upper:]' '[:lower:]')
      USER_BRANCH="$ISSUE_LOWER"
      DETECTED_PR=$(gh pr list --head "$USER_BRANCH" --json number -q '.[0].number' 2>/dev/null || true)
      if [[ -n "$DETECTED_PR" ]]; then
        BASE="$USER_BRANCH"
      elif [[ -n "${BOT_NAME:-}" ]]; then
        BOT_BRANCH="$BOT_NAME/$ISSUE_LOWER"
        DETECTED_PR=$(gh pr list --head "$BOT_BRANCH" --json number -q '.[0].number' 2>/dev/null || true)
        if [[ -n "$DETECTED_PR" ]]; then
          BASE="$BOT_BRANCH"
        fi
      fi
    fi

    if [[ -n "$BASE" ]]; then
      # Check if worktree already exists on this branch
      EXISTING_WT=$(git -C "$PROJECT_ROOT" worktree list --porcelain | grep -B2 "branch refs/heads/$BASE$" | grep "^worktree " | cut -d' ' -f2 || true)
      if [[ -n "$EXISTING_WT" ]]; then
        echo "$EXISTING_WT"
        exit 0
      fi
      git_with_github_https_auth -C "$PROJECT_ROOT" fetch origin "$BASE" >/dev/null 2>&1 || true
      git -C "$PROJECT_ROOT" worktree add --track -b "$BASE" "$WT_PATH" "origin/$BASE" >/dev/null 2>&1 || \
        git -C "$PROJECT_ROOT" worktree add "$WT_PATH" "$BASE" >/dev/null 2>&1
    else
      fetch_origin
      BRANCH="${BRANCH:-$(echo "$ISSUE" | tr '[:upper:]' '[:lower:]')}"
      git -C "$PROJECT_ROOT" worktree add --no-track -b "$BRANCH" "$WT_PATH" "origin/$DEFAULT_BRANCH" >/dev/null 2>&1
    fi

    # Set upstream tracking if remote branch exists
    CREATED_BRANCH=$(git -C "$WT_PATH" branch --show-current 2>/dev/null)
    if [[ -n "$CREATED_BRANCH" ]]; then
      _REMOTE="${BOT_REMOTE_NAME:-origin}"
      if git -C "$WT_PATH" rev-parse --verify "$_REMOTE/$CREATED_BRANCH" &>/dev/null; then
        git -C "$WT_PATH" branch --set-upstream-to="$_REMOTE/$CREATED_BRANCH" "$CREATED_BRANCH" >/dev/null 2>&1 || true
        git -C "$WT_PATH" merge --ff-only "$_REMOTE/$CREATED_BRANCH" >/dev/null 2>&1 || true
      fi
    fi

    setup_codex_worktree "$WT_PATH"
    echo "$WT_PATH"
    ;;

  list)
    git -C "$PROJECT_ROOT" worktree list
    ;;

  remove)
    ARG="${2:?Error: remove requires an issue ID or path}"
    # Accept either issue ID or direct path
    if [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi
    # Auto-relocate if cwd is inside the worktree being removed
    WT_REAL="$(cd "$WT_PATH" 2>/dev/null && pwd -P)" || WT_REAL=""
    CWD_REAL="$(pwd -P)"
    if [[ -n "$WT_REAL" && "$CWD_REAL" == "$WT_REAL"* ]]; then
      cd "$PROJECT_ROOT"
      echo "Relocated cwd to $PROJECT_ROOT" >&2
    fi
    BRANCH=""
    if [[ -d "$WT_PATH" ]]; then
      BRANCH=$(git -C "$WT_PATH" branch --show-current 2>/dev/null)
      remove_symlinks "$WT_PATH"
      git -C "$PROJECT_ROOT" worktree remove --force "$WT_PATH"
      # Safety net: remove directory if git left it behind
      [[ -d "$WT_PATH" ]] && rm -rf "$WT_PATH"
    fi
    git -C "$PROJECT_ROOT" worktree prune
    # Only delete local branch if merged (branch -d checks this). If the
    # worktree was removed but branch deletion is unsafe, report exactly what
    # remains instead of letting set -e exit silently after partial cleanup.
    BRANCH_DELETE_FAILED=false
    if [[ -n "$BRANCH" ]] && git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
      DELETE_OUTPUT=""
      if ! DELETE_OUTPUT=$(git -C "$PROJECT_ROOT" branch -d "$BRANCH" 2>&1); then
        BRANCH_DELETE_FAILED=true
        echo "Error: Removed worktree but could not delete local branch '$BRANCH'." >&2
        echo "  Remaining branch: $BRANCH" >&2
        echo "  Worktree path removed/pruned: $WT_PATH" >&2
        echo "  Safe delete refused by: git branch -d $BRANCH" >&2
        if [[ -n "$DELETE_OUTPUT" ]]; then
          printf '%s\n' "$DELETE_OUTPUT" | sed 's/^/  git: /' >&2
        fi
        echo "  After verifying it is safe, delete manually with: git -C \"$PROJECT_ROOT\" branch -D \"$BRANCH\"" >&2
      fi
    fi
    echo "Removed: $WT_PATH"
    if [[ -n "$WT_REAL" && "$CWD_REAL" == "$WT_REAL"* ]]; then
      echo "" >&2
      echo "Warning: Session cwd was inside deleted worktree. Start a new session from:" >&2
      echo "  $PROJECT_ROOT" >&2
    fi
    if [[ "$BRANCH_DELETE_FAILED" == true ]]; then
      exit 1
    fi
    ;;

  cleanup)
    git_with_github_https_auth -C "$PROJECT_ROOT" fetch --prune origin
    for wt in $(git -C "$PROJECT_ROOT" worktree list --porcelain | grep "^worktree " | grep -v "$PROJECT_ROOT$" | cut -d' ' -f2); do
      BRANCH=$(git -C "$wt" branch --show-current 2>/dev/null)
      if [[ -n "$BRANCH" ]] && git -C "$PROJECT_ROOT" branch -d "$BRANCH" 2>/dev/null; then
        remove_symlinks "$wt"
        git -C "$PROJECT_ROOT" worktree remove --force "$wt" 2>/dev/null && echo "Cleaned: $wt"
        [[ -d "$wt" ]] && rm -rf "$wt"
      fi
    done
    ;;

  path)
    worktree_path "${2:?Error: path requires an issue ID}"
    ;;

  exists)
    WT_PATH="$(worktree_path "${2:?Error: exists requires an issue ID}")"
    [[ -d "$WT_PATH" ]] && echo "true" || echo "false"
    ;;

  check)
    UNCOMMITTED="false"
    UNPUSHED="false"
    UNPUSHED_LIST=""
    if ! git -C "$PROJECT_ROOT" diff --quiet HEAD 2>/dev/null || ! git -C "$PROJECT_ROOT" diff --cached --quiet HEAD 2>/dev/null; then
      UNCOMMITTED="true"
    fi
    UNPUSHED_COMMITS=$(git -C "$PROJECT_ROOT" log "origin/$DEFAULT_BRANCH..$DEFAULT_BRANCH" --oneline 2>/dev/null)
    if [[ -n "$UNPUSHED_COMMITS" ]]; then
      UNPUSHED="true"
      UNPUSHED_LIST=$(echo "$UNPUSHED_COMMITS" | jq -R -s -c 'split("\n") | map(select(. != ""))')
    fi
    echo "{\"uncommitted\": $UNCOMMITTED, \"unpushed\": $UNPUSHED, \"unpushed_commits\": ${UNPUSHED_LIST:-[]}}"
    ;;

  push)
    if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
      echo "Usage: $0 push [ID|/path] [--set-upstream|-u] [--no-rebase]"
      echo ""
      echo "Push worktree branch to remote. Auto-rebases onto origin/$DEFAULT_BRANCH first."
      echo "Uses BOT_REMOTE_NAME from project config if set, otherwise falls back to origin."
      echo ""
      echo "Options:"
      echo "  -u, --set-upstream    Set upstream tracking branch"
      echo "  --no-rebase           Skip auto-rebase"
      exit 0
    fi
    ARG="${2:-}"
    SET_UPSTREAM=""
    AUTO_REBASE=true
    shift 2 || shift || true
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -u|--set-upstream) SET_UPSTREAM="-u"; shift ;;
        --no-rebase) AUTO_REBASE=false; shift ;;
        *) shift ;;
      esac
    done

    if [[ -z "$ARG" ]]; then
      WT_PATH="$PWD"
    elif [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    elif WT_PATH="$(current_checkout_path_for_issue "$ARG")"; then
      :
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi

    if ! is_git_worktree_path "$WT_PATH"; then
      echo "Error: Not a git worktree: $WT_PATH" >&2
      exit 1
    fi

    REMOTE="${BOT_REMOTE_NAME:-origin}"
    if ! git -C "$WT_PATH" remote get-url "$REMOTE" >/dev/null 2>&1; then
      echo "Warning: Remote '$REMOTE' not found, falling back to origin" >&2
      REMOTE="origin"
    fi

    if [[ "$AUTO_REBASE" == true ]]; then
      git_with_github_https_auth -C "$PROJECT_ROOT" fetch origin >/dev/null 2>&1 || true
      CURRENT_BRANCH=$(git -C "$WT_PATH" branch --show-current 2>/dev/null)
      if [[ -n "$CURRENT_BRANCH" && "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]]; then
        if ! git -C "$WT_PATH" rebase "origin/$DEFAULT_BRANCH" >/dev/null 2>&1; then
          git -C "$WT_PATH" rebase --abort >/dev/null 2>&1 || true
          echo "Error: Rebase onto origin/$DEFAULT_BRANCH failed (conflicts). Push with --no-rebase or resolve manually." >&2
          exit 1
        fi
        # Rebase can replace symlinks with tracked content — restore them
        setup_worktree_links "$WT_PATH"
      fi
    fi

    CURRENT_BRANCH=$(git -C "$WT_PATH" branch --show-current 2>/dev/null)
    if [[ -z "$SET_UPSTREAM" && -n "$CURRENT_BRANCH" ]]; then
      UPSTREAM=$(git -C "$WT_PATH" config "branch.${CURRENT_BRANCH}.remote" 2>/dev/null || true)
      [[ -z "$UPSTREAM" ]] && SET_UPSTREAM="-u"
    fi

    if [[ -n "$SET_UPSTREAM" ]]; then
      git_with_github_https_auth -C "$WT_PATH" push "$SET_UPSTREAM" "$REMOTE" "HEAD:refs/heads/${CURRENT_BRANCH}"
    else
      git_with_github_https_auth -C "$WT_PATH" push "$REMOTE" HEAD
    fi
    ;;

  fix-links)
    # Restore symlinks in a worktree (run after manual rebase/merge that clobbers them)
    ARG="${2:-}"
    if [[ -z "$ARG" ]]; then
      WT_PATH="$PWD"
    elif [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi
    if ! is_git_worktree_path "$WT_PATH"; then
      echo "Error: Not a git worktree: $WT_PATH" >&2
      exit 1
    fi
    setup_worktree_links "$WT_PATH"
    echo "Restored symlinks in $WT_PATH"
    ;;

  codex-setup)
    # Codex Desktop owns worktree creation. This command applies the same
    # project-local setup that `create` applies after git has already created
    # the worktree: env/config symlinks, configured copies/dirs, optional bot
    # git config, optional bot remote, and lightweight dependency bootstrap.
    ARG="${2:-}"
    if [[ -z "$ARG" ]]; then
      WT_PATH="$PWD"
    elif [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi
    if ! is_git_worktree_path "$WT_PATH"; then
      echo "Error: Not a git worktree: $WT_PATH" >&2
      exit 1
    fi
    setup_codex_worktree "$WT_PATH"
    echo "Configured Codex worktree: $WT_PATH"
    ;;

  codex-branch)
    # Codex Desktop may create an app-managed branch name. Normalize the
    # current worktree to the issue branch expected by orch before
    # running `orch start <ISSUE>`.
    ISSUE="${2:?Error: codex-branch requires an issue ID or branch name}"
    ARG="${3:-}"
    if [[ -z "$ARG" ]]; then
      WT_PATH="$PWD"
    elif [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi
    if ! is_git_worktree_path "$WT_PATH"; then
      echo "Error: Not a git worktree: $WT_PATH" >&2
      exit 1
    fi

    TARGET_BRANCH="$(issue_branch_name "$ISSUE")"
    CURRENT_BRANCH="$(git -C "$WT_PATH" branch --show-current 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" == "$TARGET_BRANCH" ]]; then
      echo "Codex worktree already on $TARGET_BRANCH: $WT_PATH"
      exit 0
    fi

    fetch_origin
    _REMOTE="${BOT_REMOTE_NAME:-origin}"
    if git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$TARGET_BRANCH"; then
      git -C "$WT_PATH" switch "$TARGET_BRANCH" >/dev/null 2>&1 || {
        echo "Error: Branch '$TARGET_BRANCH' already exists and cannot be checked out in $WT_PATH" >&2
        exit 1
      }
    elif git -C "$PROJECT_ROOT" rev-parse --verify "$_REMOTE/$TARGET_BRANCH" >/dev/null 2>&1; then
      git -C "$WT_PATH" switch -c "$TARGET_BRANCH" --track "$_REMOTE/$TARGET_BRANCH" >/dev/null 2>&1
    elif [[ -n "$CURRENT_BRANCH" ]]; then
      git -C "$WT_PATH" branch -m "$TARGET_BRANCH"
    else
      git -C "$WT_PATH" switch -c "$TARGET_BRANCH" >/dev/null 2>&1
    fi

    if git -C "$WT_PATH" rev-parse --verify "$_REMOTE/$TARGET_BRANCH" >/dev/null 2>&1; then
      git -C "$WT_PATH" branch --set-upstream-to="$_REMOTE/$TARGET_BRANCH" "$TARGET_BRANCH" >/dev/null 2>&1 || true
    fi
    setup_codex_worktree "$WT_PATH"
    echo "Codex worktree branch ready: $TARGET_BRANCH ($WT_PATH)"
    ;;

  codex-cleanup)
    # Codex Desktop owns worktree/branch deletion. This hook is intentionally
    # non-destructive and does not remove symlinks: if the app fails to delete
    # the worktree immediately after cleanup, mutating tracked symlink paths can
    # leave the worktree dirty. Project-level teardown (containers, caches)
    # belongs in the Codex environment cleanup script after this command.
    ARG="${2:-}"
    if [[ -z "$ARG" ]]; then
      WT_PATH="$PWD"
    elif [[ "$ARG" == */* ]]; then
      WT_PATH="$ARG"
    else
      WT_PATH="$(worktree_path "$ARG")"
    fi
    echo "Codex cleanup hook complete; app owns worktree deletion: $WT_PATH"
    ;;

  *)
    echo "Usage: $0 create|list|remove|cleanup|path|exists|check|push|fix-links|codex-setup|codex-branch|codex-cleanup [ID|/path] [options]" >&2
    exit 1
    ;;
esac
