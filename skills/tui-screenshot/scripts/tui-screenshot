#!/usr/bin/env python3
"""Portable terminal/TUI screenshot helper.

Captures tmux ANSI panes and renders static PNGs or animated GIFs.
"""
from __future__ import annotations

import argparse
import json
import math
import os
import re
import shutil
import shlex
import subprocess
import sys
import tempfile
import time
import unicodedata
from dataclasses import dataclass, replace
from pathlib import Path
from typing import Iterable

try:
    from wcwidth import wcwidth as _wcwidth
except Exception:  # pragma: no cover - optional dependency fallback
    def _wcwidth(ch: str) -> int:
        if not ch:
            return 0
        if unicodedata.combining(ch):
            return 0
        return 2 if unicodedata.east_asian_width(ch) in {"F", "W"} else 1

try:
    from PIL import Image, ImageDraw, ImageFont, ImageSequence
except Exception as exc:  # pragma: no cover - exercised by users without Pillow
    print("Missing Python dependency: Pillow (PIL).", file=sys.stderr)
    print("Install suggestions:", file=sys.stderr)
    print("  macOS:          python3 -m pip install --user pillow", file=sys.stderr)
    print("  Debian/Ubuntu:  sudo apt-get install python3-pil", file=sys.stderr)
    print("  Fedora:         sudo dnf install python3-pillow", file=sys.stderr)
    print("  Arch:           sudo pacman -S python-pillow", file=sys.stderr)
    print(f"Original import error: {exc}", file=sys.stderr)
    raise SystemExit(2)

DEFAULT_BG = (26, 27, 38)
DEFAULT_FG = (192, 202, 245)
TAB_WIDTH = 8
BOX = set("─━│┃┏┓┗┛┠┨┬┴┼├┤┌┐└┘")
ANSI_RE = re.compile(r"\x1b\[([0-9;]*)m")
HEX_RE = re.compile(r"#[0-9a-fA-F]{6}")
COLOR_EMOJI_RANGES = (
    (0x1F000, 0x1FAFF),  # emoji, pictographs, symbols, transport, flags, etc.
    (0x1FC00, 0x1FFFF),
)
SYMBOL_FALLBACK_RANGES = (
    (0x2600, 0x27BF),  # misc symbols + dingbats, e.g. ✦
    (0xE000, 0xF8FF),  # private-use nerd/powerline glyphs
)


@dataclass(frozen=True)
class Style:
    fg: tuple[int, int, int] | None = None
    bg: tuple[int, int, int] | None = None
    bold: bool = False
    inverse: bool = False


@dataclass
class Cell:
    ch: str
    style: Style


@dataclass
class RenderConfig:
    crop: str = "auto"
    pad: int = 0
    font_family: str | None = None
    font_size: int | None = None
    font_scale: float = 1.55
    cell_height_percent: float | None = None
    terminal_config: Path | None = None
    pi_settings: Path | None = None
    max_dimension: int = 2000


@dataclass
class TerminalStyle:
    background: tuple[int, int, int] = DEFAULT_BG
    foreground: tuple[int, int, int] = DEFAULT_FG
    palette: dict[int, tuple[int, int, int]] | None = None
    font_family: str | None = None
    font_size: float | None = None
    cell_height_percent: float | None = None


def hex_rgb(value: object, fallback: tuple[int, int, int]) -> tuple[int, int, int]:
    if isinstance(value, str) and HEX_RE.fullmatch(value.strip()):
        value = value.strip()
        return tuple(int(value[i : i + 2], 16) for i in (1, 3, 5))  # type: ignore[return-value]
    return fallback


def parse_key_value_config(path: Path | None) -> dict[str, list[str]]:
    values: dict[str, list[str]] = {}
    if not path or not path.exists():
        return values
    for line in path.read_text(errors="ignore").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, value = stripped.split("=", 1)
        key = key.strip()
        value = value.strip()
        if value.startswith('"') and value.endswith('"'):
            try:
                value = shlex.split(value)[0]
            except Exception:
                value = value[1:-1]
        values.setdefault(key, []).append(value)
    return values


def parse_percent(value: str | None) -> float | None:
    if not value:
        return None
    value = value.strip()
    try:
        if value.endswith("%"):
            return float(value[:-1])
        return float(value)
    except ValueError:
        return None


def parse_terminal_style(config: RenderConfig) -> TerminalStyle:
    kv = parse_key_value_config(config.terminal_config)
    style = TerminalStyle(palette={})
    if "background" in kv:
        style.background = hex_rgb(kv["background"][-1], DEFAULT_BG)
    if "foreground" in kv:
        style.foreground = hex_rgb(kv["foreground"][-1], DEFAULT_FG)
    for entry in kv.get("palette", []):
        if "=" not in entry:
            continue
        idx, color = entry.split("=", 1)
        try:
            style.palette[int(idx.strip())] = hex_rgb(color.strip(), DEFAULT_FG)
        except ValueError:
            pass
    if "font-family" in kv:
        style.font_family = kv["font-family"][-1]
    if "font-size" in kv:
        try:
            style.font_size = float(kv["font-size"][-1])
        except ValueError:
            pass
    if "adjust-cell-height" in kv:
        style.cell_height_percent = parse_percent(kv["adjust-cell-height"][-1])

    # Pi theme background is often more accurate than raw terminal background for Pi TUI exports.
    if config.pi_settings and config.pi_settings.exists():
        try:
            settings = json.loads(config.pi_settings.read_text())
            theme_name = settings.get("theme")
            if theme_name:
                theme_path = config.pi_settings.parent / "themes" / f"{theme_name}.json"
                theme = json.loads(theme_path.read_text())
                value: object = theme.get("export", {}).get("pageBg") or "bgBase"
                for _ in range(8):
                    if isinstance(value, str) and value in theme.get("vars", {}):
                        value = theme["vars"][value]
                        continue
                    if isinstance(value, str) and value in theme.get("colors", {}):
                        value = theme["colors"][value]
                        continue
                    break
                style.background = hex_rgb(value, style.background)
        except Exception:
            pass

    if config.font_family:
        style.font_family = config.font_family
    if config.font_size:
        style.font_size = config.font_size
    if config.cell_height_percent is not None:
        style.cell_height_percent = config.cell_height_percent
    return style


def color_from_256(index: int, palette: dict[int, tuple[int, int, int]] | None) -> tuple[int, int, int]:
    if palette and index in palette:
        return palette[index]
    if index < 16:
        defaults = [
            (0, 0, 0), (205, 49, 49), (13, 188, 121), (229, 229, 16),
            (36, 114, 200), (188, 63, 188), (17, 168, 205), (229, 229, 229),
            (102, 102, 102), (241, 76, 76), (35, 209, 139), (245, 245, 67),
            (59, 142, 234), (214, 112, 214), (41, 184, 219), (255, 255, 255),
        ]
        return defaults[index]
    if 16 <= index <= 231:
        index -= 16
        r = index // 36
        g = (index % 36) // 6
        b = index % 6
        conv = lambda v: 0 if v == 0 else 55 + v * 40
        return (conv(r), conv(g), conv(b))
    gray = 8 + (index - 232) * 10
    return (gray, gray, gray)


def apply_sgr(style: Style, params: str, terminal: TerminalStyle) -> Style:
    codes = [0] if params == "" else [int(p) if p else 0 for p in params.split(";")]
    s = style
    i = 0
    while i < len(codes):
        code = codes[i]
        if code == 0:
            s = Style()
        elif code == 1:
            s = replace(s, bold=True)
        elif code == 22:
            s = replace(s, bold=False)
        elif code == 7:
            s = replace(s, inverse=True)
        elif code == 27:
            s = replace(s, inverse=False)
        elif code == 39:
            s = replace(s, fg=None)
        elif code == 49:
            s = replace(s, bg=None)
        elif 30 <= code <= 37:
            s = replace(s, fg=color_from_256(code - 30, terminal.palette))
        elif 90 <= code <= 97:
            s = replace(s, fg=color_from_256(code - 90 + 8, terminal.palette))
        elif 40 <= code <= 47:
            s = replace(s, bg=color_from_256(code - 40, terminal.palette))
        elif 100 <= code <= 107:
            s = replace(s, bg=color_from_256(code - 100 + 8, terminal.palette))
        elif code in (38, 48) and i + 2 < len(codes):
            is_fg = code == 38
            mode = codes[i + 1]
            if mode == 2 and i + 4 < len(codes):
                color = (codes[i + 2], codes[i + 3], codes[i + 4])
                s = replace(s, fg=color) if is_fg else replace(s, bg=color)
                i += 4
            elif mode == 5 and i + 2 < len(codes):
                color = color_from_256(codes[i + 2], terminal.palette)
                s = replace(s, fg=color) if is_fg else replace(s, bg=color)
                i += 2
        i += 1
    return s


def char_width(ch: str) -> int:
    if not ch:
        return 0
    width = _wcwidth(ch)
    return width if width > 0 else 0


def is_control_char(ch: str) -> bool:
    if not ch:
        return False
    category = unicodedata.category(ch)
    return category in {"Cc", "Cf"}


def codepoint_in_ranges(ch: str, ranges: tuple[tuple[int, int], ...]) -> bool:
    return any(start <= ord(part) <= end for part in ch for start, end in ranges)


def is_color_emoji(ch: str) -> bool:
    # Keep text-presentation symbols such as ✦ in the terminal font/color; use
    # color emoji fallback for pictographs like 🦀, 🌳, and 📁 that mono fonts
    # commonly render as tofu in Pillow.
    return codepoint_in_ranges(ch, COLOR_EMOJI_RANGES)


def wants_symbol_fallback(ch: str) -> bool:
    return not is_color_emoji(ch) and codepoint_in_ranges(ch, SYMBOL_FALLBACK_RANGES)


def append_cell(cells: list[Cell], ch: str, style: Style) -> list[Cell]:
    if ch == "\r":
        return []
    if ch == "\t":
        spaces = TAB_WIDTH - (len(cells) % TAB_WIDTH)
        for _ in range(max(1, spaces)):
            cells.append(Cell(" ", style))
        return cells
    if ch == "\x1b":
        return cells
    width = char_width(ch)
    if width == 0:
        if unicodedata.combining(ch):
            if cells:
                cells[-1].ch += ch
            else:
                cells.append(Cell(ch, style))
        elif not is_control_char(ch):
            cells.append(Cell(ch, style))
        return cells
    cells.append(Cell(ch, style))
    for _ in range(width - 1):
        cells.append(Cell("", style))
    return cells


def parse_ansi(text: str, terminal: TerminalStyle) -> list[list[Cell]]:
    rows: list[list[Cell]] = []
    for line in text.splitlines():
        cells: list[Cell] = []
        style = Style()
        pos = 0
        for match in ANSI_RE.finditer(line):
            for ch in line[pos : match.start()]:
                cells = append_cell(cells, ch, style)
            style = apply_sgr(style, match.group(1), terminal)
            pos = match.end()
        for ch in line[pos:]:
            cells = append_cell(cells, ch, style)
        rows.append(cells)
    return rows


def find_popup(rows: list[list[Cell]]) -> tuple[int, int, int, int] | None:
    for top, row in enumerate(rows):
        chars = "".join(cell.ch for cell in row)
        left = chars.find("┏")
        if left == -1 or "┓" not in chars[left:]:
            continue
        right = chars.rfind("┓")
        for bottom in range(top + 1, len(rows)):
            bottom_chars = "".join(cell.ch for cell in rows[bottom])
            if len(bottom_chars) > left and bottom_chars[left] == "┗":
                return top, bottom, left, right
    return None


def find_tight(rows: list[list[Cell]], terminal: TerminalStyle) -> tuple[int, int, int, int] | None:
    min_r = min_c = 10**9
    max_r = max_c = -1
    for r, row in enumerate(rows):
        for c, cell in enumerate(row):
            fg, bg = styled_colors(cell.style, terminal)
            meaningful = cell.ch != " " or bg != terminal.background
            if meaningful:
                min_r = min(min_r, r)
                max_r = max(max_r, r)
                min_c = min(min_c, c)
                max_c = max(max_c, c)
    if max_r < 0:
        return None
    return min_r, max_r, min_c, max_c


def crop_rows(rows: list[list[Cell]], mode: str, terminal: TerminalStyle) -> list[list[Cell]]:
    if mode == "none":
        width = max((len(row) for row in rows), default=1)
        return [row + [Cell(" ", Style()) for _ in range(width - len(row))] for row in rows]
    bounds = None
    if mode in ("popup", "auto"):
        bounds = find_popup(rows)
        if mode == "popup" and bounds is None:
            raise SystemExit("No popup frame found. Use --crop auto, --crop tight, or --crop none.")
    if bounds is None and mode in ("tight", "auto"):
        bounds = find_tight(rows, terminal)
    if bounds is None:
        width = max((len(row) for row in rows), default=1)
        return [row + [Cell(" ", Style()) for _ in range(width - len(row))] for row in rows]
    top, bottom, left, right = bounds
    width = right - left + 1
    out: list[list[Cell]] = []
    for r in range(top, bottom + 1):
        row = rows[r]
        if len(row) < left + width:
            row = row + [Cell(" ", Style()) for _ in range(left + width - len(row))]
        out.append(row[left : left + width])
    return out


def fc_match(name: str, style: str | None = None) -> str | None:
    pattern = f"{name}:style={style}" if style else name
    if not shutil.which("fc-match"):
        return None
    try:
        path = subprocess.check_output(["fc-match", "-f", "%{file}\n", pattern], text=True).strip()
        return path if path and os.path.exists(path) else None
    except Exception:
        return None


def load_font(terminal: TerminalStyle, config: RenderConfig):
    family = terminal.font_family or "DejaVu Sans Mono"
    size = int(config.font_size or max(14, round((terminal.font_size or 11) * config.font_scale)))
    regular = fc_match(family, "Regular") or fc_match(family) or fc_match("DejaVu Sans Mono")
    bold = fc_match(family, "Bold") or fc_match("DejaVu Sans Mono", "Bold") or regular
    if not regular:
        # Last-resort PIL default. It will not match a terminal but keeps the tool usable.
        return ImageFont.load_default(), ImageFont.load_default(), family, size
    return ImageFont.truetype(regular, size), ImageFont.truetype(bold or regular, size), family, size


def load_symbol_font(size: int):
    for family in ("Noto Sans Symbols 2", "Noto Sans Symbols", "DejaVu Sans", "Symbols Nerd Font"):
        path = fc_match(family)
        if not path:
            continue
        try:
            return ImageFont.truetype(path, size)
        except Exception:
            continue
    return None


def load_color_emoji_font():
    # Noto Color Emoji is a bitmap color font with a fixed strike size on many
    # Linux distributions; Pillow commonly accepts 109px and rejects arbitrary
    # terminal sizes. Render at the strike size, crop, then downscale per cell.
    for family in ("Noto Color Emoji", "Twitter Color Emoji", "Apple Color Emoji", "Segoe UI Emoji"):
        path = fc_match(family)
        if not path:
            continue
        for size in (109, 128, 96, 72, 64, 48, 32):
            try:
                return ImageFont.truetype(path, size)
            except Exception:
                continue
    return None


def styled_colors(style: Style, terminal: TerminalStyle):
    fg = style.fg or terminal.foreground
    bg = style.bg or terminal.background
    if style.inverse:
        fg, bg = bg, fg
    return fg, bg


def render_ansi_text(text: str, config: RenderConfig) -> Image.Image:
    terminal = parse_terminal_style(config)
    rows = crop_rows(parse_ansi(text, terminal), config.crop, terminal)
    font, bold_font, _family, _size = load_font(terminal, config)
    symbol_font = load_symbol_font(_size)
    emoji_font = load_color_emoji_font()

    cell_w = max(1.0, font.getlength("M"))
    ascent, descent = font.getmetrics()
    base_cell_h = ascent + descent
    height_percent = config.cell_height_percent if config.cell_height_percent is not None else terminal.cell_height_percent
    height_factor = 1.0 + ((height_percent or 0.0) / 100.0)
    cell_h = max(1.0, base_cell_h * height_factor)

    probe = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789:/._-•"
    bbox = font.getbbox(probe)
    bold_bbox = bold_font.getbbox(probe)
    glyph_top = min(bbox[1], bold_bbox[1])
    glyph_bottom = max(bbox[3], bold_bbox[3])
    glyph_h = glyph_bottom - glyph_top
    text_y_adjust = (cell_h - glyph_h) / 2 - glyph_top
    bg_h = min(cell_h, base_cell_h + 1)
    bg_y_adjust = (cell_h - bg_h) / 2

    height = len(rows)
    width = max((len(row) for row in rows), default=1)
    pad = max(0, config.pad)
    img_w = math.ceil(width * cell_w) + pad * 2
    img_h = math.ceil(height * cell_h) + pad * 2
    image = Image.new("RGB", (img_w, img_h), terminal.background)
    draw = ImageDraw.Draw(image)

    def cpos(x: int) -> float:
        return pad + x * cell_w

    def rpos(y: int) -> float:
        return pad + y * cell_h

    for y, row in enumerate(rows):
        for x, cell in enumerate(row):
            _, bg = styled_colors(cell.style, terminal)
            if bg != terminal.background:
                x0 = math.floor(cpos(x))
                x1 = math.ceil(cpos(x + 1))
                y0 = math.floor(rpos(y) + bg_y_adjust)
                y1 = math.ceil(rpos(y) + bg_y_adjust + bg_h)
                draw.rectangle([x0, y0, x1, y1], fill=bg)

    def draw_color_emoji(ch: str, x: int, y: int) -> bool:
        if not emoji_font or not is_color_emoji(ch):
            return False
        canvas_size = 180
        canvas = Image.new("RGBA", (canvas_size, canvas_size), (0, 0, 0, 0))
        emoji_draw = ImageDraw.Draw(canvas)
        try:
            emoji_draw.text((0, 0), ch, font=emoji_font, embedded_color=True)
        except TypeError:
            emoji_draw.text((0, 0), ch, font=emoji_font)
        except Exception:
            return False
        bbox = canvas.getbbox()
        if not bbox:
            return False
        glyph = canvas.crop(bbox)
        width_cells = max(1, char_width(ch) or 1)
        target_w = cell_w * width_cells
        target_h = cell_h * 1.05
        scale = min(target_w / glyph.width, target_h / glyph.height)
        size = (max(1, round(glyph.width * scale)), max(1, round(glyph.height * scale)))
        glyph = glyph.resize(size, Image.Resampling.LANCZOS)
        px = round(cpos(x) + (target_w - size[0]) / 2)
        py = round(rpos(y) + (cell_h - size[1]) / 2)
        image.paste(glyph, (px, py), glyph)
        return True

    for y, row in enumerate(rows):
        for x, cell in enumerate(row):
            if not cell.ch or cell.ch in BOX or cell.ch == " ":
                continue
            fg, _ = styled_colors(cell.style, terminal)
            if draw_color_emoji(cell.ch, x, y):
                continue
            draw_font = bold_font if cell.style.bold else font
            if symbol_font and wants_symbol_fallback(cell.ch):
                draw_font = symbol_font
            draw.text((cpos(x), rpos(y) + text_y_adjust), cell.ch, fill=fg, font=draw_font)

    def draw_box(ch: str, x: int, y: int, fg):
        x0, x1 = cpos(x), cpos(x + 1)
        y0, y1 = rpos(y), rpos(y + 1)
        cx, cy = (x0 + x1) / 2, (y0 + y1) / 2
        thin = max(1, round(cell_h * 0.055))
        thick = max(2, round(cell_h * 0.105))

        def hline(a=x0, b=x1, width=thin):
            draw.line([(a, cy), (b, cy)], fill=fg, width=width)

        def vline(a=y0, b=y1, width=thin):
            draw.line([(cx, a), (cx, b)], fill=fg, width=width)

        if ch == "─":
            hline(width=thin)
        elif ch == "━":
            hline(width=thick)
        elif ch == "│":
            vline(width=thin)
        elif ch == "┃":
            vline(width=thick)
        elif ch in "┏┌":
            hline(cx, x1, thick if ch == "┏" else thin)
            vline(cy, y1, thick if ch == "┏" else thin)
        elif ch in "┓┐":
            hline(x0, cx, thick if ch == "┓" else thin)
            vline(cy, y1, thick if ch == "┓" else thin)
        elif ch in "┗└":
            hline(cx, x1, thick if ch == "┗" else thin)
            vline(y0, cy, thick if ch == "┗" else thin)
        elif ch in "┛┘":
            hline(x0, cx, thick if ch == "┛" else thin)
            vline(y0, cy, thick if ch == "┛" else thin)
        elif ch in "├┠":
            hline(cx, x1)
            vline()
        elif ch in "┤┨":
            hline(x0, cx)
            vline()
        elif ch == "┬":
            hline()
            vline(cy, y1)
        elif ch == "┴":
            hline()
            vline(y0, cy)
        elif ch == "┼":
            hline()
            vline()

    for y, row in enumerate(rows):
        for x, cell in enumerate(row):
            if cell.ch in BOX:
                fg, _ = styled_colors(cell.style, terminal)
                draw_box(cell.ch, x, y, fg)
    return image


def capture_tmux(target: str, history: bool = False) -> str:
    if not shutil.which("tmux"):
        raise SystemExit("tmux is required for capture/snap/record, but it was not found in PATH.")
    cmd = ["tmux", "capture-pane", "-e", "-p", "-t", target]
    if history:
        cmd.extend(["-S", "-"])
    return subprocess.check_output(cmd, text=True, errors="replace")


def constrain_image(image: Image.Image, max_dimension: int) -> Image.Image:
    if max_dimension <= 0:
        return image
    largest = max(image.width, image.height)
    if largest <= max_dimension:
        return image
    scale = max_dimension / largest
    size = (max(1, round(image.width * scale)), max(1, round(image.height * scale)))
    return image.resize(size, Image.Resampling.LANCZOS)


def write_image(image: Image.Image, output: Path) -> None:
    output.parent.mkdir(parents=True, exist_ok=True)
    image.save(output, optimize=True)


def normalize_frames(frames: list[Image.Image], bg: tuple[int, int, int]) -> list[Image.Image]:
    width = max(frame.width for frame in frames)
    height = max(frame.height for frame in frames)
    out: list[Image.Image] = []
    for frame in frames:
        if frame.size == (width, height):
            out.append(frame.convert("P", palette=Image.Palette.ADAPTIVE))
            continue
        canvas = Image.new("RGB", (width, height), bg)
        canvas.paste(frame, (0, 0))
        out.append(canvas.convert("P", palette=Image.Palette.ADAPTIVE))
    return out


def add_render_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--crop", choices=["auto", "popup", "tight", "none"], default="auto")
    parser.add_argument("--pad", type=int, default=0, help="pixels of padding outside the crop (default: 0)")
    parser.add_argument("--terminal-config", type=Path, default=Path.home() / ".config" / "ghostty" / "config")
    parser.add_argument("--pi-settings", type=Path, default=Path.home() / ".pi" / "agent" / "settings.json")
    parser.add_argument("--font-family")
    parser.add_argument("--font-size", type=int)
    parser.add_argument("--font-scale", type=float, default=1.55)
    parser.add_argument("--cell-height-percent", type=float)
    parser.add_argument("--max-dimension", type=int, default=2000, help="scale output so width/height are at most this many pixels; 0 disables (default: 2000)")


def config_from_args(args: argparse.Namespace) -> RenderConfig:
    return RenderConfig(
        crop=args.crop,
        pad=args.pad,
        font_family=args.font_family,
        font_size=args.font_size,
        font_scale=args.font_scale,
        cell_height_percent=args.cell_height_percent,
        terminal_config=args.terminal_config,
        pi_settings=args.pi_settings,
        max_dimension=args.max_dimension,
    )


def cmd_doctor(_args: argparse.Namespace) -> int:
    print("tui-screenshot doctor")
    print(f"python: {sys.executable}")
    print("Pillow: ok")
    print(f"tmux: {shutil.which('tmux') or 'missing'}")
    print(f"fc-match: {shutil.which('fc-match') or 'missing'}")
    for tool in ["screencapture", "grim", "slurp", "gnome-screenshot", "import", "scrot"]:
        path = shutil.which(tool)
        if path:
            print(f"pixel-capture {tool}: {path}")
    return 0


def cmd_capture(args: argparse.Namespace) -> int:
    text = capture_tmux(args.target, args.history)
    args.output.parent.mkdir(parents=True, exist_ok=True)
    args.output.write_text(text, encoding="utf-8")
    print(f"wrote {args.output}")
    return 0


def cmd_render(args: argparse.Namespace) -> int:
    config = config_from_args(args)
    text = args.input.read_text(encoding="utf-8", errors="replace")
    image = constrain_image(render_ansi_text(text, config), config.max_dimension)
    write_image(image, args.output)
    print(f"wrote {args.output} {image.size[0]}x{image.size[1]}")
    return 0


def cmd_snap(args: argparse.Namespace) -> int:
    config = config_from_args(args)
    text = capture_tmux(args.target, args.history)
    image = constrain_image(render_ansi_text(text, config), config.max_dimension)
    write_image(image, args.output)
    print(f"wrote {args.output} {image.size[0]}x{image.size[1]}")
    return 0


def delays_for(inputs: list[Path], delays: list[int]) -> list[int]:
    if not delays:
        return [1200] * len(inputs)
    if len(delays) == 1:
        return [delays[0]] * len(inputs)
    if len(delays) != len(inputs):
        raise SystemExit("Provide either one --delay or one --delay per --input.")
    return delays


def cmd_gif(args: argparse.Namespace) -> int:
    config = config_from_args(args)
    frames = [constrain_image(render_ansi_text(path.read_text(encoding="utf-8", errors="replace"), config), config.max_dimension) for path in args.input]
    terminal = parse_terminal_style(config)
    normalized = normalize_frames(frames, terminal.background)
    durations = delays_for(args.input, args.delay)
    args.output.parent.mkdir(parents=True, exist_ok=True)
    normalized[0].save(args.output, save_all=True, append_images=normalized[1:], duration=durations, loop=0, optimize=True)
    print(f"wrote {args.output} {normalized[0].size[0]}x{normalized[0].size[1]} frames={len(normalized)}")
    return 0


def cmd_record(args: argparse.Namespace) -> int:
    config = config_from_args(args)
    interval = 1.0 / args.fps
    count = max(1, int(math.ceil(args.duration * args.fps)))
    frames: list[Image.Image] = []
    for idx in range(count):
        started = time.monotonic()
        text = capture_tmux(args.target, args.history)
        frames.append(constrain_image(render_ansi_text(text, config), config.max_dimension))
        if idx != count - 1:
            elapsed = time.monotonic() - started
            time.sleep(max(0.0, interval - elapsed))
    terminal = parse_terminal_style(config)
    normalized = normalize_frames(frames, terminal.background)
    args.output.parent.mkdir(parents=True, exist_ok=True)
    normalized[0].save(args.output, save_all=True, append_images=normalized[1:], duration=int(interval * 1000), loop=0, optimize=True)
    print(f"wrote {args.output} {normalized[0].size[0]}x{normalized[0].size[1]} frames={len(normalized)}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Capture terminal/TUI screenshots from tmux ANSI output.")
    sub = parser.add_subparsers(dest="command", required=True)

    doctor = sub.add_parser("doctor", help="check runtime dependencies")
    doctor.set_defaults(func=cmd_doctor)

    capture = sub.add_parser("capture", help="capture a tmux pane to raw ANSI text")
    capture.add_argument("--target", default=":.", help="tmux target pane (default: :.)")
    capture.add_argument("--output", type=Path, required=True)
    capture.add_argument("--history", action="store_true", help="capture full scrollback instead of visible pane")
    capture.set_defaults(func=cmd_capture)

    render = sub.add_parser("render", help="render a raw ANSI capture to PNG")
    render.add_argument("--input", type=Path, required=True)
    render.add_argument("--output", type=Path, required=True)
    add_render_args(render)
    render.set_defaults(func=cmd_render)

    snap = sub.add_parser("snap", help="capture a tmux pane and render to PNG")
    snap.add_argument("--target", default=":.")
    snap.add_argument("--output", type=Path, required=True)
    snap.add_argument("--history", action="store_true")
    add_render_args(snap)
    snap.set_defaults(func=cmd_snap)

    gif = sub.add_parser("gif", help="render ANSI frames into an animated GIF")
    gif.add_argument("--input", type=Path, action="append", required=True)
    gif.add_argument("--delay", type=int, action="append", default=[], help="frame delay in milliseconds")
    gif.add_argument("--output", type=Path, required=True)
    add_render_args(gif)
    gif.set_defaults(func=cmd_gif)

    record = sub.add_parser("record", help="record a tmux pane to animated GIF for a duration")
    record.add_argument("--target", default=":.")
    record.add_argument("--output", type=Path, required=True)
    record.add_argument("--duration", type=float, default=4.0)
    record.add_argument("--fps", type=float, default=4.0)
    record.add_argument("--history", action="store_true")
    add_render_args(record)
    record.set_defaults(func=cmd_record)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
