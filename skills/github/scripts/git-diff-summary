#!/bin/bash
# Git diff domain summary - group changed files by domain with stats and risk flags
# Usage: git-diff-summary [base-branch]
#        git-diff-summary main
#        git-diff-summary --staged

set -euo pipefail

show_help() {
    cat << 'EOF'
Git Diff Domain Summary

Groups changed files by domain (auto-detected from top-level directories)
with stats and risk flags. Designed for review routing decisions.

Usage: git-diff-summary [-C path] [base-branch]

Arguments:
  base-branch    Compare against this branch (default: main)
  -C path        Run as if started in <path> (worktree support)
  --staged       Show only staged changes
  --head         Show uncommitted changes vs HEAD

Output: JSON with scope (production|support), domain groupings, stats, and risk flags
EOF
}

main() {
    local base="main"
    local diff_args=""
    local git_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help; exit 0 ;;
            --staged) diff_args="--staged"; shift ;;
            --head) diff_args="HEAD"; shift ;;
            -C) git_dir="$2"; shift 2 ;;
            *) base="$1"; shift ;;
        esac
    done

    # Determine diff command
    local diff_ref
    if [ -n "$diff_args" ]; then
        diff_ref="$diff_args"
    else
        diff_ref="${base}...HEAD"
    fi

    # Use -C path if provided, otherwise repo root
    if [ -n "$git_dir" ]; then
        cd "$git_dir"
    else
        cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    fi

    # Get file list with status (A/M/D/R)
    local files
    files=$(git diff --name-status $diff_ref 2>/dev/null || echo "")

    if [ -z "$files" ]; then
        echo '{"files_changed": 0, "scope": "support", "domains": {}, "risk_flags": []}'
        exit 0
    fi

    # Get stats
    local stats
    stats=$(git diff --stat --stat-count=999 $diff_ref 2>/dev/null | tail -1 || echo "0 files changed")

    # Detect risk flags via grep (avoids passing huge diffs through jq)
    local risk_flags="[]"
    local flags=()
    local rust_diff_added
    rust_diff_added=$(git diff $diff_ref -- '*.rs' 2>/dev/null | grep -E '^\+' || true)

    if echo "$rust_diff_added" | grep -qE '^\+.*unsafe '; then flags+=("unsafe_code_added"); fi
    if echo "$rust_diff_added" | grep -qE '^\+.*#\[repr\(C\)\]'; then flags+=("repr_c_struct_changed"); fi
    if echo "$rust_diff_added" | grep -qE '^\+.*extern "C"'; then flags+=("extern_c_changed"); fi
    if echo "$rust_diff_added" | grep -qE '^\+.*(Atomic|atomic::)'; then flags+=("atomics_modified"); fi

    # panic/unwrap only flagged in production source (not tests/benches)
    local prod_paths
    prod_paths=$(echo "$files" | awk -F'\t' '{print $NF}' \
        | grep -E '(^|/)src/|(^|/)lib/' \
        | grep -vE '(/tests/|/benches/|/test/|/fixtures/|_tests?\.rs$|\.test\.[jt]sx?$|\.spec\.[jt]sx?$)' || true)
    if [ -n "$prod_paths" ]; then
        local prod_diff
        # shellcheck disable=SC2086
        prod_diff=$(git diff $diff_ref -- $prod_paths 2>/dev/null | grep -E '^\+' || true)
        if echo "$prod_diff" | grep -qE '^\+.*(panic!|unwrap\(\))'; then flags+=("panic_path_added"); fi
    fi

    if [ ${#flags[@]} -gt 0 ]; then
        risk_flags=$(printf '"%s"\n' "${flags[@]}" | jq -s '.')
    fi

    # Classify files into domains and build output.
    # Domain = top-level directory name. Standard infrastructure dirs are grouped.
    echo "$files" | jq -Rs --arg stats "$stats" --argjson risk_flags "$risk_flags" '
        # Parse file list
        split("\n") | map(select(length > 0)) | map(
            capture("^(?<status>[AMDRC])[0-9]*\t(?<path>.+)$") // null
        ) | map(select(. != null)) |

        # Classify each file into domain + scope
        map(. + {
            domain: (
                if .path | test("^docs/")
                    then "docs"
                elif .path | test("^(tools|scripts|\\.github|\\.ci|\\.circleci|\\.gitlab|infra|deploy|terraform|pulumi)/")
                    then "infra"
                else
                    (.path | split("/")[0] // "root")
                end
            ),
            file_scope: (
                if .path | test("(/tests?/|/benches?/|/fixtures/|_tests?\\.rs$|\\.test\\.[jt]sx?$|\\.spec\\.[jt]sx?$)")
                    then "test"
                elif .path | test("^docs/")
                    then "docs"
                elif .path | test("^(tools|scripts|\\.github|\\.ci|\\.circleci|\\.gitlab|infra|deploy|terraform|pulumi)/")
                    then "infra"
                else "production"
                end
            )
        }) |

        # Capture scope before grouping (production if any prod file touched)
        . as $all_files |

        # Group by domain
        group_by(.domain) | map({
            key: .[0].domain,
            value: {
                files: [.[] | .path],
                count: length,
                added: [.[] | select(.status == "A")] | length,
                modified: [.[] | select(.status == "M")] | length,
                deleted: [.[] | select(.status == "D")] | length
            }
        }) | from_entries |

        # Parse stats line
        . as $domains |
        ($stats | capture("(?<files>[0-9]+) files? changed(, (?<ins>[0-9]+) insertions?\\(\\+\\))?(, (?<del>[0-9]+) deletions?\\(-\\))?") //
            {files: "0", ins: "0", del: "0"}) as $s |

        {
            files_changed: ($s.files | tonumber),
            insertions: (($s.ins // "0") | tonumber),
            deletions: (($s.del // "0") | tonumber),
            scope: (if ($all_files | any(.file_scope == "production")) then "production" else "support" end),
            domains: $domains,
            risk_flags: $risk_flags
        }
    '
}

main "$@"
