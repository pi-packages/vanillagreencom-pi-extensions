#!/usr/bin/env bash
# Launch one or more work item worktrees in a separate terminal/window.
# This is a handoff helper only; it does not monitor spawned sessions.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)"
SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
WORKTREE_CLI="${WORKTREE_CLI:-$SKILLS_DIR/worktree/scripts/worktree}"
GH_ISSUE_PATTERN="${GH_ISSUE_PATTERN:-[A-Z]+-[0-9]+}"

TRACKER="linear"
REPO=""
TERMINAL_MODE=""
HARNESS=""
CMD_TEMPLATE=""
ITEMS=()

usage() {
  cat <<'USAGE'
Usage: open-terminal [--tracker linear|github] [--repo OWNER/REPO] ITEM... [options]

Options:
  --harness <name>  claude, codex, opencode, pi
  --tmux            Open tmux windows in the current session
  --ghostty         Open Ghostty/GUI terminals
  --cmd "..."       Custom command; {issue}, {item}, and {repo} are replaced
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tracker) TRACKER="$2"; shift 2 ;;
    --tracker=*) TRACKER="${1#--tracker=}"; shift ;;
    --repo) REPO="$2"; shift 2 ;;
    --repo=*) REPO="${1#--repo=}"; shift ;;
    --tmux) TERMINAL_MODE="tmux"; shift ;;
    --ghostty) TERMINAL_MODE="ghostty"; shift ;;
    --harness) HARNESS="$2"; shift 2 ;;
    --harness=*) HARNESS="${1#--harness=}"; shift ;;
    --cmd) CMD_TEMPLATE="$2"; shift 2 ;;
    --cmd=*) CMD_TEMPLATE="${1#--cmd=}"; shift ;;
    --help|-h) usage; exit 0 ;;
    *) ITEMS+=("$1"); shift ;;
  esac
done

[[ -x "$WORKTREE_CLI" ]] || { echo "Error: worktree CLI not found at $WORKTREE_CLI" >&2; exit 1; }
[[ ${#ITEMS[@]} -gt 0 ]] || { echo "Error: no work items specified" >&2; exit 1; }
[[ "$TRACKER" == "linear" || "$TRACKER" == "github" ]] || { echo "Error: --tracker must be linear or github" >&2; exit 1; }
[[ -n "$HARNESS" || -n "$CMD_TEMPLATE" ]] || { echo "Error: --harness or --cmd required" >&2; exit 1; }

if [[ -z "$TERMINAL_MODE" ]]; then
  if [[ -n "${TMUX:-}" ]]; then TERMINAL_MODE="tmux"; else TERMINAL_MODE="gui"; fi
fi

resolve_repo() {
  if [[ -n "$REPO" ]]; then printf '%s\n' "$REPO"; return; fi
  gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null || true
}

start_cmd() {
  local item="$1" repo="$2"
  if [[ -n "$CMD_TEMPLATE" ]]; then
    local out="${CMD_TEMPLATE//\{issue\}/$item}"
    out="${out//\{item\}/$item}"
    out="${out//\{repo\}/$repo}"
    printf '%s\n' "$out"
    return
  fi
  case "$TRACKER:$HARNESS" in
    linear:claude)   printf "claude -n %q --model 'opus[1m]' --effort max '/orch start %s'\n" "$item" "$item" ;;
    linear:codex)    printf "codex '\$orch start %s'\n" "$item" ;;
    linear:opencode) printf "opencode --prompt '/orch start %s'\n" "$item" ;;
    linear:pi)       printf "pi '/skill:orch start %s'\n" "$item" ;;
    github:claude)   printf "claude -n github-%q --model 'opus[1m]' --effort max '/orch start github %s#%s'\n" "$item" "$repo" "$item" ;;
    github:codex)    printf "codex '\$orch start github %s#%s'\n" "$repo" "$item" ;;
    github:opencode) printf "opencode --prompt '/orch start github %s#%s'\n" "$repo" "$item" ;;
    github:pi)       printf "pi '/skill:orch start github %s#%s'\n" "$repo" "$item" ;;
    *) echo "Error: unsupported harness: $HARNESS" >&2; exit 1 ;;
  esac
}

open_tmux() {
  local dir="$1" title="$2" cmd="$3"
  [[ -n "${TMUX:-}" ]] || { echo "Error: not inside tmux" >&2; return 1; }
  local last_idx
  last_idx=$(tmux list-windows -F '#{window_index}' | tail -1)
  tmux new-window -a -t ":${last_idx}" -n "$title" -c "$dir"
  tmux send-keys "clear" Enter
  tmux send-keys -l "$cmd"
  tmux send-keys Enter
  echo "Opened tmux window '$title' in $dir"
}

open_gui() {
  local dir="$1" title="$2" cmd="$3"
  local shell_cmd="cd '$dir' && $cmd"
  if command -v ghostty >/dev/null 2>&1; then
    setsid env -u CLAUDECODE ghostty --working-directory="$dir" --title="$title" -e bash -lc "$shell_cmd" </dev/null >/dev/null 2>&1 &
  elif command -v xdg-terminal-exec >/dev/null 2>&1; then
    setsid env -u CLAUDECODE xdg-terminal-exec bash -lc "$shell_cmd" </dev/null >/dev/null 2>&1 &
  else
    echo "Error: no supported GUI terminal found" >&2
    return 1
  fi
  echo "Opened terminal '$title' in $dir"
}

repo="$(resolve_repo)"
launched=0
for raw in "${ITEMS[@]}"; do
  item="$raw"
  if [[ "$TRACKER" == "linear" ]]; then
    item="$(printf '%s' "$item" | tr '[:lower:]' '[:upper:]')"
    [[ "$item" =~ ^$GH_ISSUE_PATTERN$ ]] || { echo "Error: invalid issue id: $raw" >&2; exit 1; }
    wt="$("$WORKTREE_CLI" create "$item")"
    title="$item"
  else
    [[ "$item" =~ ^[0-9]+$ ]] || { echo "Error: GitHub item must be an issue number: $raw" >&2; exit 1; }
    [[ -n "$repo" ]] || { echo "Error: --repo OWNER/REPO required when gh repo cannot resolve" >&2; exit 1; }
    wt="$("$WORKTREE_CLI" create "issue-$item")"
    title="gh-$item"
  fi
  cmd="$(start_cmd "$item" "$repo")"
  if [[ "$TERMINAL_MODE" == "tmux" ]]; then open_tmux "$wt" "$title" "$cmd"; else open_gui "$wt" "$title" "$cmd"; fi
  launched=$((launched + 1))
done

echo "Done: launched $launched handoff session(s)."
