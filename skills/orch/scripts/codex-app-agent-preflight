#!/usr/bin/env bash
# Check whether Codex Desktop app-created worktrees can see generated agents at
# thread startup. Setup hooks run too late for subagent type discovery, so local
# ignored .codex/agents TOMLs are a warning that child threads may fall back to
# worker unless the user accepts that risk.

set -euo pipefail

worktree="${1:-.}"
repo_root="$(git -C "$worktree" rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "$repo_root" ]]; then
  jq -n \
    --arg status "error" \
    --arg severity "error" \
    --arg message "not inside a git repository" \
    '{status: $status, severity: $severity, ok: false, requires_confirmation: false, message: $message, tracked_agents: 0, visible_agents: 0}'
  exit 1
fi

tracked_agents="$(git -C "$repo_root" ls-files '.codex/agents/*.toml' | wc -l | tr -d ' ')"
visible_agents=0
if [[ -d "$repo_root/.codex/agents" ]]; then
  visible_agents="$(find "$repo_root/.codex/agents" -maxdepth 1 -type f -name '*.toml' | wc -l | tr -d ' ')"
fi

status="ok"
message="tracked Codex generated agents are available to app-created worktrees"
ok=true
severity="info"
requires_confirmation=false

if [[ "$tracked_agents" -eq 0 && "$visible_agents" -gt 0 ]]; then
  status="untracked"
  severity="warning"
  message="generated Codex agents exist locally but are not tracked; app-created worktrees will not see them before subagent type discovery and may fall back to worker"
  ok=false
  requires_confirmation=true
elif [[ "$tracked_agents" -eq 0 ]]; then
  status="missing"
  severity="warning"
  message="no tracked generated Codex agents found at .codex/agents/*.toml; app-created worktrees may fall back to worker"
  ok=false
  requires_confirmation=true
fi

jq -n \
  --arg status "$status" \
  --arg severity "$severity" \
  --arg message "$message" \
  --arg repo_root "$repo_root" \
  --argjson ok "$ok" \
  --argjson requires_confirmation "$requires_confirmation" \
  --argjson tracked_agents "$tracked_agents" \
  --argjson visible_agents "$visible_agents" \
  '{
    status: $status,
    severity: $severity,
    ok: $ok,
    requires_confirmation: $requires_confirmation,
    message: $message,
    repo_root: $repo_root,
    tracked_agents: $tracked_agents,
    visible_agents: $visible_agents
  }'

exit 0
