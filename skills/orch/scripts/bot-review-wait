#!/usr/bin/env bash
# Wait for bot review(s) to complete on a PR.
#
# Supports multiple bot reviewers with heterogeneous signaling:
#   - Claude-style: formal PR review (APPROVED|CHANGES_REQUESTED) + sticky
#                   "View job" comment with checklist + verdict text.
#   - Codex-style:  reactions on the PR body or earliest comment
#                   (👀 = reviewing, 👍 = approved); inline review threads
#                   when changes are requested.
#
# Usage: bot-review-wait <PR#> [poll_interval] [max_wait]
#                         [--json] [--reviewers "bot1,bot2"] [--skip "bot3,bot4"]
#
# Environment:
#   BOT_REVIEWERS          Comma-separated bot logins to wait for (fallback if
#                          --reviewers not passed). Default: auto-detect.
#   BOT_SKIPPED_REVIEWERS  Comma-separated bot logins to mark as "skipped"
#                          even if they show signal — they will not block
#                          completion. Combined with --skip.
#   BOT_CHECK_NAME         Optional CI check name treated as an early review
#                          completion signal (legacy fast-path for Claude).
#                          When unset, PR-level approved reviewDecision can
#                          still resolve stale pending bot signals if no
#                          unresolved review threads remain.
#
# Exit codes:
#   0 - All configured reviewers reached a terminal state (approved/changes/skipped)
#   1 - Timeout: at least one reviewer still pending
#   2 - Checklist timeout: terminal verdicts in but bot still posting threads
#   3 - GitHub auth/API error before reliable status could be read
#
# JSON output (always when --json):
#   {
#     "status": "complete" | "checklist_timeout" | "timeout" | "no_reviewers" | "error",
#     "verdict": "approved" | "changes" | "pending",
#     "elapsed_seconds": <int>,
#     "error": <string>,           # only when status == "error"
#     "reviewers": [ {reviewer,status,signals,updated_at,unresolved_threads} ... ],
#     "pending_reviewers":  [...],
#     "approved_reviewers": [...],
#     "changes_reviewers":  [...],
#     "skipped_reviewers":  [...]
#   }
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
_CALLER_GH_TOKEN_SET="${GH_TOKEN+x}"
_CALLER_GH_TOKEN="${GH_TOKEN:-}"
_CALLER_GITHUB_TOKEN_SET="${GITHUB_TOKEN+x}"
_CALLER_GITHUB_TOKEN="${GITHUB_TOKEN:-}"
_CALLER_GH_BOT_TOKEN_SET="${GH_BOT_TOKEN+x}"
_CALLER_GH_BOT_TOKEN="${GH_BOT_TOKEN:-}"
# shellcheck source=lib/vstack-env.sh
source "$SCRIPT_DIR/lib/vstack-env.sh"
vstack_load_project_env "$PROJECT_ROOT"
if [[ -n "$_CALLER_GH_TOKEN_SET" ]]; then
  export GH_TOKEN="$_CALLER_GH_TOKEN"
fi
if [[ -n "$_CALLER_GITHUB_TOKEN_SET" ]]; then
  export GITHUB_TOKEN="$_CALLER_GITHUB_TOKEN"
fi
if [[ -n "$_CALLER_GH_BOT_TOKEN_SET" ]]; then
  export GH_BOT_TOKEN="$_CALLER_GH_BOT_TOKEN"
fi
unset _CALLER_GH_TOKEN_SET _CALLER_GH_TOKEN _CALLER_GITHUB_TOKEN_SET _CALLER_GITHUB_TOKEN _CALLER_GH_BOT_TOKEN_SET _CALLER_GH_BOT_TOKEN

GIT_HOST_CLI="${GIT_HOST_CLI:-$SKILLS_DIR/github/scripts/github.sh}"
if [[ ! -x "$GIT_HOST_CLI" ]]; then
  echo "Error: GIT_HOST_CLI not found at '$GIT_HOST_CLI'. Is the github skill installed?" >&2
  exit 1
fi

# Source the github lib for bot_review_status
GH_LIB="$SKILLS_DIR/github/scripts/lib/github-api.sh"
if [[ ! -f "$GH_LIB" ]]; then
  echo "Error: github lib not found at '$GH_LIB'." >&2
  exit 1
fi
# shellcheck source=/dev/null
source "$GH_LIB"

# Shared GH_TOKEN/GITHUB_TOKEN sanitizer (see lib/gh-auth.sh).
# shellcheck source=lib/gh-auth.sh
source "$SCRIPT_DIR/lib/gh-auth.sh"

# --- arg parse ---
JSON_OUTPUT=false
REVIEWERS_ARG=""
SKIP_ARG=""
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUTPUT=true; shift ;;
    --reviewers) REVIEWERS_ARG="$2"; shift 2 ;;
    --reviewers=*) REVIEWERS_ARG="${1#--reviewers=}"; shift ;;
    --skip) SKIP_ARG="$2"; shift 2 ;;
    --skip=*) SKIP_ARG="${1#--skip=}"; shift ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

PR_NUM="${POSITIONAL[0]:?Usage: bot-review-wait <PR#> [poll_interval] [max_wait] [--json] [--reviewers \"bot1,bot2\"] [--skip \"bot3,bot4\"]}"
POLL_INTERVAL="${POSITIONAL[1]:-15}"
MAX_WAIT="${POSITIONAL[2]:-600}"
START_TIME="$(date +%s)"
elapsed=0

update_elapsed() {
  local now
  now="$(date +%s)"
  elapsed=$((now - START_TIME))
  if [[ "$elapsed" -gt "$MAX_WAIT" ]]; then
    elapsed="$MAX_WAIT"
  fi
}

remaining_wait() {
  update_elapsed
  local remaining=$((MAX_WAIT - elapsed))
  if [[ "$remaining" -gt 0 ]]; then
    printf '%s' "$remaining"
  else
    printf '0'
  fi
}

deadline_reached() {
  update_elapsed
  [[ "$elapsed" -ge "$MAX_WAIT" ]]
}

sleep_until_deadline() {
  local requested="$1"
  local remaining
  remaining="$(remaining_wait)"
  [[ "$remaining" -le 0 ]] && return 1
  if [[ "$requested" -gt "$remaining" ]]; then
    requested="$remaining"
  fi
  sleep "$requested"
  update_elapsed
}

emit_error() {
  local message="$1"
  if $JSON_OUTPUT; then
    jq -n \
      --arg s "error" \
      --arg v "pending" \
      --argjson elapsed "$elapsed" \
      --arg error "$message" \
      '{
        status: $s,
        verdict: $v,
        elapsed_seconds: $elapsed,
        error: $error,
        reviewers: [],
        pending_reviewers: [],
        approved_reviewers: [],
        changes_reviewers: [],
        skipped_reviewers: []
      }'
  fi
  echo "Error: $message" >&2
}

ensure_gh_ready() {
  if ! command -v gh >/dev/null 2>&1; then
    echo "gh CLI not found" >&2
    return 1
  fi

  local auth_output
  if auth_output=$(gh auth status 2>&1); then
    return 0
  fi

  # A bad GH_TOKEN/GITHUB_TOKEN masks gh keyring auth. If keyring auth works
  # with those variables removed, prefer the working auth source instead of
  # polling until timeout with every API read degraded to "unknown".
  orch_sanitize_gh_env
  if gh auth status >/dev/null 2>&1; then
    return 0
  fi

  # Final fallback: a stale env token plus broken keyring may still recover
  # if project config/secrets carry a valid GH_BOT_TOKEN. Drop any remaining
  # stale env token first so we are not just retrying the bad one.
  unset GH_TOKEN GITHUB_TOKEN
  if orch_load_env_bot_token "$PROJECT_ROOT" && \
     gh auth status >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "$auth_output" >&2
  return 1
}

if ! ensure_gh_ready; then
  emit_error "GitHub CLI authentication failed"
  exit 3
fi

# --- skipped set ---
declare -A SKIPPED=()
for s in $(printf '%s' "${SKIP_ARG:-${BOT_SKIPPED_REVIEWERS:-}}" | tr ',' ' '); do
  [[ -n "$s" ]] && SKIPPED["$s"]=1
done

# --- reviewer set ---
REVIEWERS=()
if [[ -n "$REVIEWERS_ARG" ]]; then
  IFS=',' read -ra REVIEWERS <<< "$REVIEWERS_ARG"
elif [[ -n "${BOT_REVIEWERS:-}" ]]; then
  IFS=',' read -ra REVIEWERS <<< "$BOT_REVIEWERS"
else
  detected_reviewers=""
  if ! detected_reviewers=$(detect_bot_reviewers "$PR_NUM"); then
    emit_error "GitHub API failure while detecting bot reviewers for PR #$PR_NUM"
    exit 3
  fi
  while IFS= read -r bot; do
    [[ -n "$bot" ]] && REVIEWERS+=("$bot")
  done <<<"$detected_reviewers"
fi

# Trim whitespace from reviewer entries.
trimmed=()
for r in "${REVIEWERS[@]:-}"; do
  r="${r#"${r%%[![:space:]]*}"}"
  r="${r%"${r##*[![:space:]]}"}"
  [[ -n "$r" ]] && trimmed+=("$r")
done
REVIEWERS=("${trimmed[@]}")

PHASE3_MAX=300       # Sticky-checklist wait after terminal verdict
PHASE3_INTERVAL=10

# Per-iteration: collect all reviewers' status into a JSON array.
collect_reviewers() {
  local arr='[]'
  for r in "${REVIEWERS[@]}"; do
    local entry
    if ! entry=$(bot_review_status "$PR_NUM" "$r"); then
      return 1
    fi
    if [[ -n "${SKIPPED[$r]:-}" ]]; then
      entry=$(jq -c '.status = "skipped" | .signals += ["config:skipped"]' <<<"$entry")
    fi
    arr=$(jq -c --argjson e "$entry" '. + [$e]' <<<"$arr")
  done
  printf '%s' "$arr"
}

pr_review_decision_approved() {
  local pr_json
  if ! pr_json=$(gh pr view "$PR_NUM" --json reviewDecision 2>/dev/null); then
    return 1
  fi
  [[ "$(jq -r '.reviewDecision // ""' <<<"$pr_json")" == "APPROVED" ]]
}

bot_check_name_passed() {
  [[ -z "${BOT_CHECK_NAME:-}" ]] && return 0

  local check_lines
  check_lines=$(gh pr checks "$PR_NUM" 2>&1 | grep -E "^\s*${BOT_CHECK_NAME}\s" || true)
  [[ -n "$check_lines" ]] && echo "$check_lines" | grep -qE '\bpass\b'
}

unresolved_pr_threads_count() {
  local repo_info owner repo threads
  repo_info=$(get_repo_info) || return 1
  owner=$(get_owner "$repo_info")
  repo=$(get_repo "$repo_info")

  local query='
query($owner: String!, $repo: String!, $pr: Int!) {
  repository(owner: $owner, name: $repo) {
    pullRequest(number: $pr) {
      reviewThreads(first: 100) {
        nodes { isResolved }
      }
    }
  }
}'
  threads=$(gh_graphql "$query" -F owner="$owner" -F repo="$repo" -F pr="$PR_NUM") || return 1
  jq '[.repository.pullRequest.reviewThreads.nodes[]? | select((.isResolved // false) == false)] | length' <<<"$threads"
}

apply_pr_terminal_fallback() {
  local entries="$1"

  # Do not turn an explicit changes request into approval.
  if jq -e 'any(.status == "changes")' >/dev/null <<<"$entries"; then
    printf '%s' "$entries"
    return 0
  fi

  # GitHub's PR-level reviewDecision can become terminal while a bot's sticky
  # status comment still looks pending. Trust it only when the configured bot
  # check has passed (if one is configured) and no unresolved review threads
  # remain, so comment triage can proceed instead of polling stale prose.
  if ! pr_review_decision_approved || ! bot_check_name_passed; then
    printf '%s' "$entries"
    return 0
  fi

  local unresolved
  if ! unresolved=$(unresolved_pr_threads_count); then
    printf '%s' "$entries"
    return 0
  fi
  if [[ "$unresolved" -gt 0 ]]; then
    printf '%s' "$entries"
    return 0
  fi

  jq -c '
    map(
      if .status == "pending" or .status == "unknown" then
        .status = "approved"
        | .signals += ["pr_review_decision:approved", "pr_threads:clear"]
      else
        .
      end
    )
  ' <<<"$entries"
}

collect_reviewers_or_exit() {
  local entries
  if ! entries=$(collect_reviewers); then
    emit_error "GitHub API failure while reading bot review status for PR #$PR_NUM"
    exit 3
  fi
  entries=$(apply_pr_terminal_fallback "$entries")
  printf '%s' "$entries"
}

# Bucket reviewer logins by status; aggregate verdict.
# Echoes 5 newline-separated JSON arrays + verdict on a final line:
#   pending\napproved\nchanges\nskipped\nunknown\nverdict
bucket_reviewers() {
  local entries="$1"
  jq -r '
    {
      pending:  [.[] | select(.status == "pending")  | .reviewer],
      approved: [.[] | select(.status == "approved") | .reviewer],
      changes:  [.[] | select(.status == "changes")  | .reviewer],
      skipped:  [.[] | select(.status == "skipped")  | .reviewer],
      unknown:  [.[] | select(.status == "unknown")  | .reviewer]
    } |
    (.pending  | tojson),
    (.approved | tojson),
    (.changes  | tojson),
    (.skipped  | tojson),
    (.unknown  | tojson)
  ' <<<"$entries"
}

# Combine per-reviewer statuses into a single verdict for legacy callers.
# Precedence: changes > pending > approved > unknown.
# "skipped" reviewers are excluded from verdict aggregation.
aggregate_verdict() {
  local entries="$1"
  jq -r '
    [.[] | select(.status != "skipped")] as $effective |
    if   ($effective | any(.status == "changes"))  then "changes"
    elif ($effective | any(.status == "pending"))  then "pending"
    elif ($effective | any(.status == "unknown") and ($effective | all(.status != "approved"))) then "pending"
    elif ($effective | any(.status == "approved")) then "approved"
    else "pending" end
  ' <<<"$entries"
}

# A reviewer is "blocking" if status is unknown or pending — i.e. we cannot
# yet say it has reached a terminal state.
any_blocking() {
  local entries="$1"
  local n
  n=$(jq '[.[] | select(.status == "pending" or .status == "unknown")] | length' <<<"$entries")
  [[ "$n" -gt 0 ]]
}

# Sticky-checklist done check (still uses GIT_HOST_CLI for the default
# Claude-style sticky bot — this only matters for that bot's path).
sticky_checklist_done() {
  local body
  body=$("$GIT_HOST_CLI" sticky-comment "$PR_NUM" --body 2>/dev/null || echo "")
  [[ -z "$body" ]] && return 0
  local unchecked
  unchecked=$(printf '%s\n' "$body" | grep -c '^[[:space:]]*- \[ \]' || true)
  [[ "$unchecked" -eq 0 ]]
}

# Wait up to PHASE3_MAX (capped by remaining MAX_WAIT) for the sticky
# checklist to drain after a terminal verdict has arrived.
# Returns 0 if drained, 1 on timeout. Updates global $elapsed.
wait_for_checklist() {
  update_elapsed
  local p3_end=$((elapsed + PHASE3_MAX))
  [[ "$p3_end" -gt "$MAX_WAIT" ]] && p3_end="$MAX_WAIT"
  if sticky_checklist_done; then
    return 0
  fi
  while ! deadline_reached && [[ "$elapsed" -lt "$p3_end" ]]; do
    if sticky_checklist_done; then
      return 0
    fi
    if ! $JSON_OUTPUT; then
      echo "Waiting for bot to finish posting threads..." >&2
    fi
    local remaining_phase=$((p3_end - elapsed))
    [[ "$remaining_phase" -le 0 ]] && break
    local sleep_for="$PHASE3_INTERVAL"
    [[ "$sleep_for" -gt "$remaining_phase" ]] && sleep_for="$remaining_phase"
    sleep_until_deadline "$sleep_for" || break
  done
  sticky_checklist_done
}

pr_terminal_fallback_applied() {
  local entries="$1"
  jq -e 'any(.signals[]? == "pr_review_decision:approved")' >/dev/null <<<"$entries"
}

terminal_posting_done() {
  local entries="$1"

  # The PR-level fallback already verified that no unresolved review threads
  # remain. Do not wait on stale sticky checklist prose after that point.
  if pr_terminal_fallback_applied "$entries"; then
    return 0
  fi

  wait_for_checklist
}

emit_result() {
  local status="$1"
  local entries="$2"
  local verdict
  verdict=$(aggregate_verdict "$entries")

  local pending_arr approved_arr changes_arr skipped_arr unknown_arr
  {
    read -r pending_arr
    read -r approved_arr
    read -r changes_arr
    read -r skipped_arr
    read -r unknown_arr
  } < <(bucket_reviewers "$entries")

  if $JSON_OUTPUT; then
    jq -n \
      --arg s "$status" \
      --arg v "$verdict" \
      --argjson elapsed "$elapsed" \
      --argjson reviewers "$entries" \
      --argjson pending  "$pending_arr" \
      --argjson approved "$approved_arr" \
      --argjson changes  "$changes_arr" \
      --argjson skipped  "$skipped_arr" \
      --argjson unknown  "$unknown_arr" \
      '{
        status: $s,
        verdict: $v,
        elapsed_seconds: $elapsed,
        reviewers: $reviewers,
        pending_reviewers:  $pending  + $unknown,
        approved_reviewers: $approved,
        changes_reviewers:  $changes,
        skipped_reviewers:  $skipped
      }'
  else
    case "$status" in
      complete)
        echo "Bot reviews complete (verdict: $verdict; reviewers: ${REVIEWERS[*]:-none})" >&2 ;;
      checklist_timeout)
        echo "Bot review verdict received (${verdict}) but checklist still pending after ${PHASE3_MAX}s." >&2 ;;
      timeout)
        echo "Bot review timeout after ${MAX_WAIT}s (verdict: $verdict; pending: $pending_arr)" >&2 ;;
      no_reviewers)
        echo "No bot reviewers detected on PR #$PR_NUM — returning unknown." >&2 ;;
    esac
  fi
}

# --- Edge case: no reviewers at all ---
if [[ ${#REVIEWERS[@]} -eq 0 ]]; then
  emit_result "no_reviewers" "[]"
  exit 0
fi

# --- BOT_CHECK_NAME fast-path (legacy Claude CI signal) ---
PHASE1_MAX=60
phase1_end=$((elapsed + PHASE1_MAX))
[[ $phase1_end -gt $MAX_WAIT ]] && phase1_end=$MAX_WAIT
BOT_CHECK_NAME="${BOT_CHECK_NAME:-}"

while [ $elapsed -lt $phase1_end ] && [[ -n "$BOT_CHECK_NAME" ]]; do
  check_lines=""
  check_lines=$(gh pr checks "$PR_NUM" 2>&1 | grep -E "^\s*${BOT_CHECK_NAME}\s" || true)
  if [ -n "$check_lines" ]; then
    if echo "$check_lines" | grep -qE '\b(pass|fail)\b'; then
      entries=$(collect_reviewers_or_exit)
      if ! any_blocking "$entries"; then
        if terminal_posting_done "$entries"; then
          emit_result "complete" "$entries"
          exit 0
        else
          emit_result "checklist_timeout" "$entries"
          exit 2
        fi
      fi
    elif ! echo "$check_lines" | grep -qE '\bpending\b'; then
      # All skipping → bot won't run (CI-side decision). Treat as no signal —
      # fall through to the per-reviewer poll loop.
      break
    fi
  fi
  sleep_until_deadline "$POLL_INTERVAL" || break
done

# --- Main poll loop: per-reviewer status until all terminal or timeout ---
last_entries=""
while ! deadline_reached; do
  entries=$(collect_reviewers_or_exit)
  last_entries="$entries"
  update_elapsed
  if ! any_blocking "$entries"; then
    if terminal_posting_done "$entries"; then
      emit_result "complete" "$entries"
      exit 0
    else
      # Refresh entries — the checklist wait can take minutes; reviewers
      # may have updated their state in the meantime.
      entries=$(collect_reviewers_or_exit)
      if any_blocking "$entries"; then
        # Something regressed to pending while we waited on the checklist.
        # Continue the main loop to re-evaluate.
        continue
      fi
      emit_result "checklist_timeout" "$entries"
      exit 2
    fi
  fi
  sleep_until_deadline "$POLL_INTERVAL" || break
done

# --- Timeout: one final read ---
entries=$(collect_reviewers_or_exit)
update_elapsed
if ! any_blocking "$entries"; then
  # Crossed the line right at the bell.
  if terminal_posting_done "$entries"; then
    emit_result "complete" "$entries"
    exit 0
  fi
  emit_result "checklist_timeout" "$entries"
  exit 2
fi
emit_result "timeout" "$entries"
exit 1
