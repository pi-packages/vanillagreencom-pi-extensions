#!/usr/bin/env bash
# Store locally computed safe parallel groups. No session supervision.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)"
CACHE_DIR="${ORCH_CACHE_DIR:-$PROJECT_ROOT/.cache/orch}"
GROUPS_FILE="$CACHE_DIR/parallel-groups.json"
LOCK_FILE="$GROUPS_FILE.lock"

ensure_file() {
  mkdir -p "$CACHE_DIR"
  [[ -f "$GROUPS_FILE" ]] || printf '{"groups":[]}\n' >"$GROUPS_FILE"
}

with_lock() {
  local fd
  exec {fd}>"$LOCK_FILE"
  flock -w 5 "$fd" || { echo "Error: could not acquire lock" >&2; exit 1; }
  "$@"
  flock -u "$fd"
  exec {fd}>&-
}

cmd_read() {
  ensure_file
  if [[ "${1:-}" == "--all" ]]; then
    jq -c '.groups' "$GROUPS_FILE"
  else
    jq -c '[.groups[] | select(.verdict == "safe")]' "$GROUPS_FILE"
  fi
}

cmd_write() {
  local input="$1"
  ensure_file
  jq -e 'type == "object" and (.issues | type == "array") and (.verdict | type == "string")' >/dev/null <<<"$input"
  _write() {
    local gid tmp
    gid=$(jq '[.groups[].group_id] | (max // 0) + 1' "$GROUPS_FILE")
    tmp="$GROUPS_FILE.tmp.$$"
    jq --argjson g "$(jq -c --argjson gid "$gid" '. + {group_id: $gid}' <<<"$input")" '.groups += [$g]' "$GROUPS_FILE" >"$tmp"
    mv "$tmp" "$GROUPS_FILE"
    echo "$gid"
  }
  with_lock _write
}

cmd_clear() {
  ensure_file
  local group_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --group) group_id="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  _clear() {
    if [[ -n "$group_id" ]]; then
      jq --argjson gid "$group_id" '.groups |= map(select(.group_id != $gid))' "$GROUPS_FILE" >"$GROUPS_FILE.tmp.$$"
      mv "$GROUPS_FILE.tmp.$$" "$GROUPS_FILE"
    else
      printf '{"groups":[]}\n' >"$GROUPS_FILE"
    fi
  }
  with_lock _clear
}

cmd_lookup() {
  local item="$1"
  ensure_file
  jq -r --arg id "$item" '[.groups[] | select(.verdict == "safe") | select(.issues[] == $id) | .group_id] | first // empty' "$GROUPS_FILE"
}

cmd_needs_refresh() {
  [[ $# -ge 2 ]] || { echo "skip: <2 issues"; return 1; }
  ensure_file
  local cands all_covered uncovered
  cands=$(printf '%s\n' "$@" | jq -R . | jq -s -c .)
  all_covered=$(jq -n --argjson cands "$cands" --slurpfile data "$GROUPS_FILE" '
    ([$data[0].groups[]? | .issues[]?] | unique) as $covered |
    [$cands[] | select(. as $c | $covered | index($c) | not)] | length == 0')
  if [[ "$all_covered" == "true" ]]; then
    echo "fresh: all $# covered"
    return 1
  fi
  uncovered=$(jq -n --argjson cands "$cands" --slurpfile data "$GROUPS_FILE" '
    ([$data[0].groups[]? | .issues[]?] | unique) as $covered |
    [$cands[] | select(. as $c | $covered | index($c) | not)] | join(", ")')
  echo "new: $uncovered not analyzed"
  return 0
}

case "${1:-}" in
  read) shift; cmd_read "$@" ;;
  write) cmd_write "${2:?JSON argument required}" ;;
  clear) shift; cmd_clear "$@" ;;
  lookup) cmd_lookup "${2:?Issue ID required}" ;;
  needs-refresh) shift; cmd_needs_refresh "$@" ;;
  --help|-h)
    echo "Usage: parallel-groups read|write|clear|lookup|needs-refresh"
    ;;
  *)
    echo "Usage: parallel-groups read|write|clear|lookup|needs-refresh" >&2
    exit 1
    ;;
esac
